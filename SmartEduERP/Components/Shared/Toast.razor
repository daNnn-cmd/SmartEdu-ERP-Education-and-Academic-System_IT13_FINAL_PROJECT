@using Microsoft.AspNetCore.Components
@inject IJSRuntime JS

<div class="toast-container">
    @foreach (var toast in toasts)
    {
        <div class="toast @toast.Type @(toast.Visible ? "show" : "")" @onclick="() => RemoveToast(toast.Id)">
            <div class="toast-header">
                <div class="toast-icon">
                    @if (toast.Type == "success")
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                    }
                    else if (toast.Type == "error")
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="15" y1="9" x2="9" y2="15"></line>
                            <line x1="9" y1="9" x2="15" y2="15"></line>
                        </svg>
                    }
                    else if (toast.Type == "warning")
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                            <line x1="12" y1="9" x2="12" y2="13"></line>
                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                        </svg>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    }
                </div>
                <strong class="toast-title">@toast.Title</strong>
                <button type="button" class="toast-close" @onclick="() => RemoveToast(toast.Id)">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>
            <div class="toast-body">
                @toast.Message
            </div>
        </div>
    }
</div>

@code {
    private List<ToastModel> toasts = new();
    private int nextId = 1;

    [Inject] private IToastService ToastService { get; set; } = default!;

    protected override void OnInitialized()
    {
        ToastService.OnShow += ShowToast;
    }

    private async void ShowToast(string message, string title, string type)
    {
        var toast = new ToastModel
        {
            Id = nextId++,
            Message = message,
            Title = title,
            Type = type,
            Visible = true
        };

        toasts.Insert(0, toast);
        StateHasChanged();

        // Auto remove after 5 seconds
        await Task.Delay(5000);
        if (toasts.Contains(toast))
        {
            toast.Visible = false;
            StateHasChanged();
            await Task.Delay(300); // Wait for fade out animation
            toasts.Remove(toast);
            StateHasChanged();
        }
    }

    private async void RemoveToast(int id)
    {
        var toast = toasts.FirstOrDefault(t => t.Id == id);
        if (toast != null)
        {
            toast.Visible = false;
            StateHasChanged();
            await Task.Delay(300); // Wait for fade out animation
            toasts.Remove(toast);
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        ToastService.OnShow -= ShowToast;
    }

    private class ToastModel
    {
        public int Id { get; set; }
        public string Message { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public bool Visible { get; set; }
    }
}