@page "/register"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using SmartEduERP.Data
@using Microsoft.EntityFrameworkCore
@inject AuthService AuthService
@inject StudentService StudentService
@inject EmailService EmailService
@inject SmartEduDbContext DbContext
@inject NavigationManager Navigation

<PageTitle>Register - Academic System</PageTitle>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('/images/rg.jpg') center/cover no-repeat;
        padding: 2rem;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        position: relative;
    }

        /* Optional: Add a semi-transparent overlay for better text readability */
        .login-page::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.4);
            z-index: 0;
        }

    .login-card {
        width: 100%;
        max-width: 800px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        border: 1px solid #e5e5e5;
        overflow: hidden;
        position: relative; /* Ensure it stays above the overlay */
        z-index: 1;
        padding: 0;
    }

    .login-header {
        padding: 1.5rem;
        border-bottom: 1px solid #e5e5e5;
        background: #fafafa;
        text-align: center;
    }

    .login-logo {
        width: 40px;
        height: 40px;
        margin: 0 auto 1rem;
        display: block;
    }

    .login-title {
        font-size: 1.75rem;
        font-weight: 600;
        color: #000;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .login-subtitle {
        font-size: 0.875rem;
        color: #737373;
        line-height: 1.5;
        font-weight: 400;
    }

    .login-body {
        width: 100%;
        padding: 1.5rem;
    }

    .form-group {
        margin-bottom: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }

    .form-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: #000;
    }

    .form-control {
        width: 100%;
        padding: 0.75rem;
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        color: #000;
        transition: all 0.2s;
        font-family: inherit;
    }

        .form-control::placeholder {
            color: #a3a3a3;
        }

        .form-control:focus {
            outline: none;
            border-color: #000;
            box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
        }

    .password-wrapper {
        position: relative;
    }

    .password-toggle {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #737373;
        cursor: pointer;
        padding: 0.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s;
    }

        .password-toggle:hover {
            color: #404040;
        }

    .btn-register {
        width: 100%;
        padding: 0.75rem 1rem;
        background: #000;
        color: white;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 1rem;
        font-family: inherit;
    }

        .btn-register:hover:not(:disabled) {
            background: #1a1a1a;
        }

        .btn-register:active:not(:disabled) {
            transform: translateY(1px);
        }

        .btn-register:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    .btn-login {
        width: 100%;
        padding: 0.75rem 1rem;
        background: transparent;
        color: #000;
        border: 1px solid #e0e0e0;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 0.75rem;
        font-family: inherit;
    }

        .btn-login:hover {
            background: #f8f8f8;
            border-color: #000;
        }

        .btn-login:active {
            transform: translateY(1px);
        }

    .error-alert {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
        padding: 0.75rem 0.875rem;
        border-radius: 6px;
        font-size: 0.8125rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .success-alert {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #16a34a;
        padding: 0.75rem 0.875rem;
        border-radius: 6px;
        font-size: 0.8125rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .error-icon {
        flex-shrink: 0;
        margin-top: 0.125rem;
    }

    .success-icon {
        flex-shrink: 0;
        margin-top: 0.125rem;
    }

    .validation-message {
        color: #dc2626;
        font-size: 0.75rem;
        margin-top: 0.25rem;
    }

    .role-select {
        width: 100%;
        padding: 0.75rem 0.875rem;
        background: #f5f5f5;
        border: 1px solid transparent;
        border-radius: 6px;
        font-size: 0.875rem;
        color: #000;
        transition: all 0.2s;
        font-family: inherit;
        cursor: pointer;
    }

        .role-select:focus {
            outline: none;
            background: #fff;
            border-color: #e0e0e0;
            box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.02);
        }

    /* Responsive design improvements */
    @@media (max-width: 640px) {
        .login-page {
            padding: 1rem;
        }

        .login-card {
            padding: 1.5rem 1.25rem;
            max-width: 100%;
        }

        .form-row {
            grid-template-columns: 1fr;
            gap: 0;
        }

        .login-title {
            font-size: 1.5rem;
        }

        .form-group {
            margin-bottom: 0.875rem;
        }
    }

    @@media (max-width: 480px) {
        .login-card {
            padding: 1.25rem 1rem;
        }

        .login-header {
            margin-bottom: 1.25rem;
        }

        .form-control, .btn-register, .btn-login {
            padding: 0.625rem 0.75rem;
        }
    }
</style>

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <img src="/images/logo.png" alt="Academic System Logo" class="login-logo" />
            <h1 class="login-title">Register Account</h1>
            <p class="login-subtitle">Join Smart EDU Academic System</p>
        </div>

        <div class="login-body">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-alert">
                    <svg class="error-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="12" y1="8" x2="12" y2="12"></line>
                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                    </svg>
                    <span>@errorMessage</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-alert">
                    <svg class="success-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                    <span>@successMessage</span>
                </div>
            }

            <EditForm Model="@registerModel" OnValidSubmit="@HandleRegister">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <div class="form-row">
                        <div>
                            <label for="firstName" class="form-label">First Name</label>
                            <InputText id="firstName" class="form-control" @bind-Value="registerModel.FirstName" placeholder="Enter your first name" />
                            <ValidationMessage For="@(() => registerModel.FirstName)" class="validation-message" />
                        </div>
                        <div>
                            <label for="lastName" class="form-label">Last Name</label>
                            <InputText id="lastName" class="form-control" @bind-Value="registerModel.LastName" placeholder="Enter your last name" />
                            <ValidationMessage For="@(() => registerModel.LastName)" class="validation-message" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="email" class="form-label">Email Address</label>
                    <input id="email"
                           type="email"
                           class="form-control"
                           @bind="registerModel.Email"
                           placeholder="Enter your email address"
                           autocomplete="email" />
                    <ValidationMessage For="@(() => registerModel.Email)" class="validation-message" />
                </div>

                <div class="form-group">
                    <label for="username" class="form-label">Username</label>
                    <input id="username"
                           type="text"
                           class="form-control"
                           @bind="registerModel.Username"
                           placeholder="Choose a username"
                           autocomplete="username" />
                    <ValidationMessage For="@(() => registerModel.Username)" class="validation-message" />
                </div>

                <div class="form-group">
                    <label for="password" class="form-label">Password</label>
                    <div class="password-wrapper">
                        <input id="password"
                               type="@(showPassword ? "text" : "password")"
                               class="form-control"
                               @bind="registerModel.Password"
                               placeholder="Create a password"
                               autocomplete="new-password" />
                        <button type="button" class="password-toggle" @onclick="TogglePasswordVisibility">
                            @if (showPassword)
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
                                    <line x1="1" y1="1" x2="23" y2="23"></line>
                                </svg>
                            }
                            else
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => registerModel.Password)" class="validation-message" />
                </div>

                <div class="form-group">
                    <label for="confirmPassword" class="form-label">Confirm Password</label>
                    <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="registerModel.ConfirmPassword" placeholder="Confirm your password" autocomplete="new-password" />
                    <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="validation-message" />
                </div>

                <div class="form-group">
                    <label for="middleName" class="form-label">Middle Name</label>
                    <InputText id="middleName" class="form-control" @bind-Value="registerModel.MiddleName" placeholder="Enter your middle name (optional)" />
                    <ValidationMessage For="@(() => registerModel.MiddleName)" class="validation-message" />
                </div>

                <div class="form-group">
                    <div class="form-row">
                        <div>
                            <label for="suffix" class="form-label">Suffix</label>
                            <InputText id="suffix" class="form-control" @bind-Value="registerModel.Suffix" placeholder="Jr., Sr., III, etc." />
                            <ValidationMessage For="@(() => registerModel.Suffix)" class="validation-message" />
                        </div>
                        <div>
                            <label for="gender" class="form-label">Gender *</label>
                            <InputSelect id="gender" class="form-control" @bind-Value="registerModel.Gender">
                                <option value="">Select gender...</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => registerModel.Gender)" class="validation-message" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <div class="form-row">
                        <div>
                            <label for="contactNumber" class="form-label">Contact Number *</label>
                            <InputText id="contactNumber" class="form-control" @bind-Value="registerModel.ContactNumber" placeholder="Enter your phone number" />
                            <ValidationMessage For="@(() => registerModel.ContactNumber)" class="validation-message" />
                        </div>
                        <div>
                            <label for="dateOfBirth" class="form-label">Date of Birth *</label>
                            <InputDate id="dateOfBirth" class="form-control" @bind-Value="registerModel.DateOfBirth" />
                            <ValidationMessage For="@(() => registerModel.DateOfBirth)" class="validation-message" />
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="address" class="form-label">Address *</label>
                    <InputTextArea id="address" class="form-control" @bind-Value="registerModel.Address" placeholder="Enter your full address" rows="3" />
                    <ValidationMessage For="@(() => registerModel.Address)" class="validation-message" />
                </div>

                <button type="submit" class="btn-register" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span>Creating Account...</span>
                    }
                    else
                    {
                        <span>Register</span>
                    }
                </button>
            </EditForm>

            <button type="button" class="btn-login" @onclick="NavigateToLogin">
                Back to Log In
            </button>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isLoading = false;
    private bool showPassword = false;

    protected override void OnInitialized()
    {
        // Set default role to Student
        registerModel.Role = "Student";
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private void NavigateToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            Console.WriteLine($"Starting registration for: {registerModel.Username}, {registerModel.Email}");

            try
            {
                var existingUser = await DbContext.UserAccounts
                    .FirstOrDefaultAsync(u => u.Username == registerModel.Username);

                if (existingUser != null)
                {
                    errorMessage = "Username already exists. Please choose a different username.";
                    isLoading = false;
                    return;
                }

                // Check if email already exists (if provided)
                if (!string.IsNullOrEmpty(registerModel.Email))
                {
                    var existingEmail = await DbContext.UserAccounts
                        .FirstOrDefaultAsync(u => u.Email == registerModel.Email);

                    if (existingEmail != null)
                    {
                        errorMessage = "Email address already exists. Please use a different email.";
                        isLoading = false;
                        return;
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error checking existing users: {ex.Message}");
                errorMessage = "Database connection error. Please try again.";
                isLoading = false;
                return;
            }

            Console.WriteLine("Username and email are available, proceeding with registration...");

            // Create user account with email support
            var newUser = new UserAccount
            {
                FirstName = registerModel.FirstName,
                LastName = registerModel.LastName,
                Username = registerModel.Username,
                Email = registerModel.Email, // Include email since column now exists
                Password = BCrypt.Net.BCrypt.HashPassword(registerModel.Password, 12),
                Role = "Student", // Default role for self-registration
                IsEmailConfirmed = true // Set to true since we're not using email confirmation yet
            };

            // Save user directly to database
            Console.WriteLine("Creating user account...");
            try
            {
                DbContext.UserAccounts.Add(newUser);
                await DbContext.SaveChangesAsync();
                Console.WriteLine($"User account created with ID: {newUser.UserId}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error creating user account: {ex.Message}");
                Console.WriteLine($"Inner exception: {ex.InnerException?.Message}");
                errorMessage = $"Registration failed: {ex.Message}";
                return;
            }

            if (newUser.UserId > 0)
            {
                Console.WriteLine("Creating synchronized student record...");
                try
                {
                    // Create corresponding student record with synchronized ID and all captured information
                    await StudentService.CreateStudentFromUserAsync(
                        newUser.UserId,
                        newUser.FirstName ?? "",
                        newUser.LastName ?? "",
                        newUser.Email ?? "", // Use the email from registration
                        registerModel.MiddleName, // Pass middle name
                        registerModel.Suffix, // Pass suffix
                        registerModel.Gender, // Pass gender
                        registerModel.ContactNumber, // Pass contact number
                        registerModel.Address, // Pass address
                        registerModel.DateOfBirth // Pass date of birth
                    );
                    Console.WriteLine($"Student record created successfully for user ID: {newUser.UserId} with complete information");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error creating student record: {ex.Message}");
                    Console.WriteLine($"Inner exception: {ex.InnerException?.Message}");
                    // Continue with registration even if student creation fails
                }

                // Show success message and redirect to login
                successMessage = "🎉 Registration successful! Your account has been created and you can now log in with your credentials.";

                // Clear the form
                registerModel = new RegisterModel();

                // Wait a moment to show the success message, then redirect to login
                await Task.Delay(3000);
                Navigation.NavigateTo("/login", true);
            }
            else
            {
                errorMessage = "Registration failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "First name is required")]
        [System.ComponentModel.DataAnnotations.StringLength(100, ErrorMessage = "First name cannot exceed 100 characters")]
        public string FirstName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Last name is required")]
        [System.ComponentModel.DataAnnotations.StringLength(100, ErrorMessage = "Last name cannot exceed 100 characters")]
        public string LastName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Please enter a valid email address")]
        [System.ComponentModel.DataAnnotations.StringLength(100, ErrorMessage = "Email cannot exceed 100 characters")]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required")]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 3, ErrorMessage = "Username must be between 3 and 100 characters")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[a-zA-Z0-9_]+$", ErrorMessage = "Username can only contain letters, numbers, and underscores")]
        public string Username { get; set; } = "";

        public string Role { get; set; } = "Student";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 12, ErrorMessage = "Password must be at least 12 characters")]
        public string Password { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please confirm your password")]
        [System.ComponentModel.DataAnnotations.Compare("Password", ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.StringLength(100, ErrorMessage = "Middle name cannot exceed 100 characters")]
        public string? MiddleName { get; set; } // Optional field

        [System.ComponentModel.DataAnnotations.StringLength(20, ErrorMessage = "Suffix cannot exceed 20 characters")]
        public string? Suffix { get; set; } // Optional field

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Gender is required")]
        [System.ComponentModel.DataAnnotations.StringLength(10, ErrorMessage = "Gender cannot exceed 10 characters")]
        public string Gender { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Contact number is required")]
        [System.ComponentModel.DataAnnotations.Phone(ErrorMessage = "Please enter a valid contact number")]
        [System.ComponentModel.DataAnnotations.StringLength(20, ErrorMessage = "Contact number cannot exceed 20 characters")]
        public string ContactNumber { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Address is required")]
        [System.ComponentModel.DataAnnotations.StringLength(255, ErrorMessage = "Address cannot exceed 255 characters")]
        public string Address { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Date of birth is required")]
        public DateTime? DateOfBirth { get; set; }
    }
}