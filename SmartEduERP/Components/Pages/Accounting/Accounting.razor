    private IEnumerable<Tax> FilteredTaxes
    {
        get
        {
            var query = taxes.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(taxSearchText))
            {
                var lower = taxSearchText.ToLower();
                query = query.Where(t =>
                    (!string.IsNullOrEmpty(t.Name) && t.Name.ToLower().Contains(lower)) ||
                    (!string.IsNullOrEmpty(t.Description) && t.Description.ToLower().Contains(lower)));
            }

            // Apply sorting
            query = taxSortColumn switch
            {
                "Name" => taxSortAscending
                    ? query.OrderBy(t => t.Name)
                    : query.OrderByDescending(t => t.Name),
                "Rate" => taxSortAscending
                    ? query.OrderBy(t => t.Rate)
                    : query.OrderByDescending(t => t.Rate),
                _ => query.OrderBy(t => t.Name)
            };

            return query;
        }
    }

