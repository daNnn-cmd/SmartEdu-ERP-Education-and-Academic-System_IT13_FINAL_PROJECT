    private int TotalTaxPages => (int)Math.Ceiling(FilteredTaxes.Count() / (double)taxPageSize);
    private int TotalAllowancePages => (int)Math.Ceiling(FilteredAllowances.Count() / (double)allowancePageSize);
    private int TotalAttendancePages => (int)Math.Ceiling(FilteredAttendance.Count() / (double)attendancePageSize);

    // Filtered collections
    private IEnumerable<TeacherIncome> FilteredIncomes
    {
        get
        {
            var query = incomes.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(incomeSearchText))
            {
                var lower = incomeSearchText.ToLower();
                query = query.Where(i =>
                    (!string.IsNullOrEmpty(i.TeacherName) && i.TeacherName.ToLower().Contains(lower)) ||
                    i.TeacherId.ToString().Contains(incomeSearchText));
            }

            if (!string.IsNullOrWhiteSpace(incomeStatusFilter))
            {
                // Note: TeacherIncome doesn't have IsActive property in your model
                // You might need to add it or use a different status filter
            }

            // Apply sorting
            query = incomeSortColumn switch
            {
                "TeacherName" => incomeSortAscending
                    ? query.OrderBy(i => i.TeacherName)
                    : query.OrderByDescending(i => i.TeacherName),
                "PeriodStartDate" => incomeSortAscending
                    ? query.OrderBy(i => i.PeriodStartDate)
                    : query.OrderByDescending(i => i.PeriodStartDate),
                "PeriodEndDate" => incomeSortAscending
                    ? query.OrderBy(i => i.PeriodEndDate)
                    : query.OrderByDescending(i => i.PeriodEndDate),
                _ => query.OrderByDescending(i => i.PeriodStartDate)
            };

            return query;
        }
    }

    private IEnumerable<TeacherIncome> FilteredPagedIncomes => FilteredIncomes
        .Skip((incomeCurrentPage - 1) * incomePageSize)
