    }

    private async Task ConfirmArchiveAsync()
    {
        if (string.IsNullOrWhiteSpace(archiveEntityType) || archiveEntityId == 0)
        {
            showArchiveModal = false;
            return;
        }

        var label = archiveEntityType;

        try
        {
            var success = false;

            if (archiveEntityType == "teacher income")
            {
                success = await AccountingService.SoftDeleteTeacherIncomeAsync(archiveEntityId);
            }
            else if (archiveEntityType == "tax")
            {
                success = await AccountingService.SoftDeleteTaxAsync(archiveEntityId);
            }
            else if (archiveEntityType == "allowance")
            {
                success = await AccountingService.SoftDeleteAllowanceAsync(archiveEntityId);
            }

            if (success)
            {
                ToastService.ShowSuccess($"The {label} has been archived.");

                // Log the archive action
                await LogClientAction("ARCHIVE", archiveEntityType == "teacher income" ? "TeacherIncome" :
                    archiveEntityType == "tax" ? "Taxes" : "Allowances",
                    $"Archived {label}: {archiveEntityName}",
                    $"ID: {archiveEntityId}");

                // Remove from current in-memory lists
                if (archiveEntityType == "teacher income")
                {
                    incomes = incomes.Where(i => i.TeacherIncomeId != archiveEntityId).ToList();
                }
                else if (archiveEntityType == "tax")
                {
                    taxes = taxes.Where(t => t.TaxId != archiveEntityId).ToList();
                }
                else if (archiveEntityType == "allowance")
                {
                    allowances = allowances.Where(a => a.AllowanceId != archiveEntityId).ToList();
                }

                await LoadDataAsync();
            }
            else
            {
                ToastService.ShowWarning($"Could not archive the {label}. It may have been removed already.");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to archive the {label}: {ex.Message}");
            await LogClientAction("ARCHIVE_ERROR", archiveEntityType == "teacher income" ? "TeacherIncome" :
                archiveEntityType == "tax" ? "Taxes" : "Allowances",
                $"Failed to archive {label} {archiveEntityName}: {ex.Message}",
                $"ID: {archiveEntityId}");
        }
        finally
        {
            showArchiveModal = false;
            archiveEntityType = string.Empty;
            archiveEntityId = 0;
            archiveEntityName = string.Empty;
            StateHasChanged();
        }
    }

    private async Task LoadAttendanceExportAsync()
    {
        if (attendanceStart == default || attendanceEnd == default)
        {
            ToastService.ShowError("Please select both period start and end dates.");
            return;
        }

        if (attendanceEnd < attendanceStart)
        {
            ToastService.ShowError("Period end date cannot be earlier than start date.");
            return;
        }

        try
        {
            attendanceExport = await HrService.GetPayrollAttendanceAsync(attendanceStart, attendanceEnd);
            attendanceCurrentPage = 1;

            await LogClientAction("LOAD", "Attendance",
                $"Loaded attendance export",
                $"Period: {attendanceStart:MM/dd/yyyy} - {attendanceEnd:MM/dd/yyyy}, Records: {attendanceExport.Count}");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to load attendance export: {ex.Message}");
            await LogClientAction("LOAD_ERROR", "Attendance",
                $"Failed to load attendance: {ex.Message}",
                $"Period: {attendanceStart:MM/dd/yyyy} - {attendanceEnd:MM/dd/yyyy}");
        }
    }

