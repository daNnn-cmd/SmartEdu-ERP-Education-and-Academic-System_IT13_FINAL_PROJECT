    private string GetSortIcon(string column, string tab)
    {
        string currentSortColumn = tab switch
        {
            "income" => incomeSortColumn,
            "tax" => taxSortColumn,
            "allowance" => allowanceSortColumn,
            "attendance" => attendanceSortColumn,
            _ => ""
        };

        bool currentSortAscending = tab switch
        {
            "income" => incomeSortAscending,
            "tax" => taxSortAscending,
            "allowance" => allowanceSortAscending,
            "attendance" => attendanceSortAscending,
            _ => true
        };

        if (currentSortColumn != column)
            return "";
        return currentSortAscending ? " ▲" : " ▼";
    }

