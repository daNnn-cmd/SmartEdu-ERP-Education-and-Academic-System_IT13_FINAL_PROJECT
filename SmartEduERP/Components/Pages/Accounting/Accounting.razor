    private class TeacherIncomeInputModel : IValidatableObject
    {
        [Required(ErrorMessage = "Teacher name is required")]
        [MaxLength(200, ErrorMessage = "Teacher name must be 200 characters or fewer")]
        public string? TeacherName { get; set; }

        [Required(ErrorMessage = "Teacher ID is required")]
        [Range(1, int.MaxValue, ErrorMessage = "Teacher ID must be greater than 0")]
        public int? TeacherId { get; set; }

        [Required(ErrorMessage = "Period start date is required")]
        public DateTime? PeriodStartDate { get; set; }

        [Required(ErrorMessage = "Period end date is required")]
        public DateTime? PeriodEndDate { get; set; }

        [Required(ErrorMessage = "Basic salary is required")]
        [Range(typeof(decimal), "0.01", "999999999", ErrorMessage = "Basic salary must be greater than 0")]
        public decimal? BasicSalary { get; set; }

        [Range(typeof(decimal), "0", "999999999", ErrorMessage = "Overtime pay cannot be negative")]
        public decimal? OvertimePay { get; set; }

        [Range(typeof(decimal), "0", "999999999", ErrorMessage = "Other income cannot be negative")]
        public decimal? OtherIncome { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (PeriodStartDate.HasValue && PeriodEndDate.HasValue && PeriodEndDate.Value < PeriodStartDate.Value)
            {
                yield return new ValidationResult(
                    "Period end date cannot be earlier than start date",
                    new[] { nameof(PeriodEndDate) });
            }
        }
    }
