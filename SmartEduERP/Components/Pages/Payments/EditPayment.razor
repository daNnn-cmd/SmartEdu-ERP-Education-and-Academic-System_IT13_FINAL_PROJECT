    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="page-header">
            <h1>Edit Payment</h1>
            <p>Update payment information and transaction details</p>
        </div>

        <div class="form-container">
            @if (loading)
            {
                <div class="loading-container">
                    <div class="spinner"></div>
                </div>
            }
            else if (payment == null)
            {
                <div class="not-found-message">
                    <div class="not-found-icon">💰</div>
                    <h3>Payment Not Found</h3>
                    <p>The payment you're looking for doesn't exist or has been removed.</p>
                    <a href="/payments" class="cancel-button" style="margin-top: 1rem;">
                        Back to Payments
                    </a>
                </div>
            }
            else
            {
                <div class="form-card">
                    <div class="form-card-header">
                        <h2>Payment Information</h2>
                    </div>
                    <div class="form-card-body">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="error-message">
                                <strong>Error:</strong> @errorMessage
                            </div>
                        }

                        <!-- Payment Details Summary -->
                        <div class="payment-details">
                            <div class="payment-details-title">Current Payment Details</div>
                            <div class="payment-details-grid">
                                <div class="payment-detail-item">
                                    <span class="payment-detail-label">Payment ID</span>
                                    <span class="payment-detail-value">#@payment.PaymentId</span>
                                </div>
                                <div class="payment-detail-item">
                                    <span class="payment-detail-label">Student</span>
                                    <span class="payment-detail-value">
                                        @if (payment.Student != null)
                                        {
                                            @payment.Student.FirstName@payment.Student.LastName
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unknown</span>
                                        }
                                    </span>
                                </div>
                                <div class="payment-detail-item">
                                    <span class="payment-detail-label">Current Amount</span>
                                    <span class="payment-detail-value">₱@payment.Amount.ToString("N2")</span>
                                </div>
                                <div class="payment-detail-item">
                                    <span class="payment-detail-label">Current Status</span>
                                    <span class="payment-detail-value">
                                        <span class="status-badge @GetStatusClass(payment.PaymentStatus)">@payment.PaymentStatus</span>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <EditForm Model="@payment" OnValidSubmit="@HandleSubmit">
                            <DataAnnotationsValidator />

                            <div class="form-grid">
                                <div class="form-group full-width">
                                    <label class="form-label">Student *</label>
                                    <InputSelect class="form-select" @bind-Value="payment.StudentId">
                                        <option value="">-- Select a student --</option>
                                        @foreach (var student in students)
                                        {
                                            <option value="@student.StudentId" selected="@(payment.StudentId == student.StudentId)">
                                                @student.FirstName @student.LastName - @student.Email
                                            </option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => payment.StudentId)" class="validation-message" />

                                    @{
                                        var selectedStudent = students.FirstOrDefault(s => s.StudentId == payment.StudentId);
                                        if (selectedStudent != null)
                                        {
                                            <div class="student-info">
                                                <div class="student-name">@selectedStudent.FirstName @selectedStudent.LastName</div>
                                                <div class="student-details">
                                                    Email: @selectedStudent.Email |
                                                    Status: <span class="badge bg-@GetStudentStatusColor(selectedStudent.EnrollmentStatus)">@selectedStudent.EnrollmentStatus</span>
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Amount (₱) *</label>
                                    <div class="amount-input-container">
                                        <InputNumber class="form-input amount-input" @bind-Value="payment.Amount" step="0.01" placeholder="0.00" />
                                        <span class="currency-symbol">₱</span>
                                    </div>
                                    <ValidationMessage For="@(() => payment.Amount)" class="validation-message" />
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Payment Date *</label>
                                    <InputDate class="form-input" @bind-Value="payment.PaymentDate" />
                                    <ValidationMessage For="@(() => payment.PaymentDate)" class="validation-message" />
                                </div>

                                <div class="form-group">
                                    <label class="form-label">Payment Method *</label>
                                    <InputSelect class="form-select" @bind-Value="payment.PaymentMethod">
                                        <option value="">-- Select payment method --</option>
                                        <option value="Cash" selected="@(payment.PaymentMethod == "Cash")">Cash</option>
                                        <option value="Credit Card" selected="@(payment.PaymentMethod == "Credit Card")">Credit Card</option>
                                        <option value="Debit Card" selected="@(payment.PaymentMethod == "Debit Card")">Debit Card</option>
                                        <option value="Bank Transfer" selected="@(payment.PaymentMethod == "Bank Transfer")">Bank Transfer</option>
                                        <option value="GCash" selected="@(payment.PaymentMethod == "GCash")">GCash</option>
                                        <option value="PayMaya" selected="@(payment.PaymentMethod == "PayMaya")">PayMaya</option>
                                        <option value="Check" selected="@(payment.PaymentMethod == "Check")">Check</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => payment.PaymentMethod)" class="validation-message" />

                                    <div class="payment-method-options">
                                        <div class="payment-method-option @(payment.PaymentMethod == "Cash" ? "selected" : "")" @onclick='() => SetPaymentMethod("Cash")'>Cash</div>
                                        <div class="payment-method-option @(payment.PaymentMethod == "GCash" ? "selected" : "")" @onclick='() => SetPaymentMethod("GCash")'>GCash</div>
                                        <div class="payment-method-option @(payment.PaymentMethod == "Bank Transfer" ? "selected" : "")" @onclick='() => SetPaymentMethod("Bank Transfer")'>Bank Transfer</div>
                                        <div class="payment-method-option @(payment.PaymentMethod == "Credit Card" ? "selected" : "")" @onclick='() => SetPaymentMethod("Credit Card")'>Credit Card</div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Payment Status *</label>
                                    <InputSelect class="form-select" @bind-Value="payment.PaymentStatus">
                                        <option value="">-- Select status --</option>
                                        <option value="Paid" selected="@(payment.PaymentStatus == "Paid")">Paid</option>
                                        <option value="Pending" selected="@(payment.PaymentStatus == "Pending")">Pending</option>
                                        <option value="Failed" selected="@(payment.PaymentStatus == "Failed")">Failed</option>
                                        <option value="Refunded" selected="@(payment.PaymentStatus == "Refunded")">Refunded</option>
                                    </InputSelect>
                                    <ValidationMessage For="@(() => payment.PaymentStatus)" class="validation-message" />
                                    <div class="status-options">
                                        <div class="status-option @(payment.PaymentStatus == "Paid" ? "selected paid" : "")" @onclick='() => SetPaymentStatus("Paid")'>Paid</div>
                                        <div class="status-option @(payment.PaymentStatus == "Pending" ? "selected pending" : "")" @onclick='() => SetPaymentStatus("Pending")'>Pending</div>
                                        <div class="status-option @(payment.PaymentStatus == "Failed" ? "selected failed" : "")" @onclick='() => SetPaymentStatus("Failed")'>Failed</div>
                                        <div class="status-option @(payment.PaymentStatus == "Refunded" ? "selected refunded" : "")" @onclick='() => SetPaymentStatus("Refunded")'>Refunded</div>
                                    </div>
                                </div>

                                
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="submit-button" disabled="@saving">
                                    @if (saving)
                                    {
                                        <div class="spinner-small"></div>
                                    }
                                    else
                                    {
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                                            <polyline points="17 21 17 13 7 13 7 21"></polyline>
                                            <polyline points="7 3 7 8 15 8"></polyline>
                                        </svg>
                                    }
                                    <span>Update Payment</span>
                                </button>
                                <a href="/payments" class="cancel-button">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                    <span>Cancel</span>
                                </a>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Payment? payment;
    private List<Student> students = new();
    private string? errorMessage;
    private bool loading = true;
    private bool saving = false;

    protected override async Task OnInitializedAsync()
    {
        students = await StudentService.GetAllStudentsAsync();
        payment = await PaymentService.GetPaymentByIdAsync(Id);
        loading = false;
    }

    private void SetPaymentMethod(string method)
    {
        if (payment != null)
        {
            payment.PaymentMethod = method;
            StateHasChanged();
        }
    }

    private void SetPaymentStatus(string status)
    {
        if (payment != null)
        {
            payment.PaymentStatus = status;
            StateHasChanged();
        }
    }

    private string GetStudentStatusColor(string? status)
    {
        return status?.ToLower() switch
        {
            "active" => "success",
            "inactive" => "secondary",
            "graduated" => "info",
            _ => "warning"
        };
    }

    private string GetStatusClass(string? status)
    {
        return status?.ToLower() switch
        {
            "paid" => "paid",
            "pending" => "pending",
            "failed" => "failed",
            "refunded" => "refunded",
            _ => "pending"
        };
    }

    private async Task HandleSubmit()
    {
        if (payment == null) return;

        saving = true;
        errorMessage = null;

        try
        {
            var currentUserId = AuthStateProvider.GetCurrentUserId();
            await PaymentService.UpdatePaymentAsync(payment, currentUserId);
            Navigation.NavigateTo("/payments");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }
}