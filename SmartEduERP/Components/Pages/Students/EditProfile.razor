@page "/students/profile/edit"
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using SmartEduERP.Components.Shared
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Student")]
@inject StudentService StudentService
@inject AuthService AuthService
@inject AuthStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Edit Profile - SmartEduERP</PageTitle>

<style>
    .dashboard-wrapper { display: flex; min-height: 100vh; background: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; }
    .sidebar { width: 260px; background: white; border-right: 1px solid #e5e5e5; position: fixed; height: 100vh; overflow-y: auto; display: flex; flex-direction: column; }
    .sidebar-header { padding: 1.25rem 1rem; border-bottom: 1px solid #e5e5e5; display: flex; align-items: center; gap: 0.75rem; }
    .sidebar-logo { width: 48px; height: 48px; }
    .sidebar-title { font-size: 1rem; font-weight: 600; margin: 0; color: #000; }
    .sidebar-subtitle { font-size: 0.75rem; color: #737373; margin: 0; }
    .sidebar-content { flex: 1; padding: 1rem 0; }
    .sidebar-section-label { padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 600; color: #737373; text-transform: uppercase; letter-spacing: 0.05em; }
    .sidebar-menu { list-style: none; padding: 0; margin: 0; }
    .sidebar-menu-item { padding: 0 0.75rem; }
    .sidebar-menu-button { width: 100%; padding: 0.625rem 0.75rem; background: none; border: none; display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; color: #404040; cursor: pointer; border-radius: 6px; transition: all 0.2s; text-decoration: none; }
    .sidebar-menu-button:hover { background: #f5f5f5; color: #000; }
    .sidebar-menu-icon { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar-footer { padding: 1rem; border-top: 1px solid #e5e5e5; }
    .user-info { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem; margin-bottom: 0.75rem; }
    .user-avatar { width: 32px; height: 32px; background: #f0f0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; }
    .user-details { flex: 1; min-width: 0; }
    .user-name { font-size: 0.875rem; font-weight: 500; color: #000; margin: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .main-content { margin-left: 260px; flex: 1; padding: 1.5rem; }
    .dashboard-header { margin-bottom: 1.5rem; }
    .form-container { max-width: 720px; }
    .content-card { background: white; border: 1px solid #e5e5e5; border-radius: 12px; overflow: hidden; }
    .content-card-header { padding: 1.25rem; border-bottom: 1px solid #e5e5e5; background: #fafafa; display: flex; justify-content: space-between; align-items: center; }
    .content-card-title { font-size: 1rem; font-weight: 600; color: #000; margin: 0; }
    .content-card-body { padding: 1.25rem; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { display: flex; flex-direction: column; }
    .form-label { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; color: #000; }
    .form-input, .form-select { padding: 0.625rem; border: 1px solid #e5e5e5; border-radius: 6px; font-size: 0.875rem; background: white; }
    .form-actions { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
    .btn-primary { background: #000; color: white; border: none; padding: 0.625rem 1.25rem; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer; }
    .btn-secondary { background: white; color: #404040; border: 1px solid #e5e5e5; padding: 0.625rem 1.25rem; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer; }
    .error-message { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.875rem; margin-bottom: 1.25rem; }
    @@media (max-width: 768px) { .main-content { margin-left: 0; } .form-grid { grid-template-columns: 1fr; } }
</style>

<div class="dashboard-wrapper">
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo.png" alt="Logo" class="sidebar-logo" />
            <div>
                <h2 class="sidebar-title">Academic System</h2>
                <p class="sidebar-subtitle">Education Management</p>
            </div>
        </div>
        <div class="sidebar-content">
            <div class="sidebar-section-label">Student Menu</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item"><a href="/student-dashboard" class="sidebar-menu-button"><svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg><span>Dashboard</span></a></li>
                <li class="sidebar-menu-item"><a href="/enrollments" class="sidebar-menu-button"><svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg><span>My Enrollments</span></a></li>
                <li class="sidebar-menu-item"><a href="/grades" class="sidebar-menu-button"><svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"></path><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg><span>My Grades</span></a></li>
                <li class="sidebar-menu-item"><a href="/students/payment" class="sidebar-menu-button"><svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg><span>Student Tuition Payments</span></a></li>
                <li class="sidebar-menu-item"><a href="/students/schedule" class="sidebar-menu-button"><svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg><span>Class Schedule</span></a></li>
                <li class="sidebar-menu-item"><a href="/students/profile" class="sidebar-menu-button"><svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg><span>My Profile</span></a></li>
            </ul>
        </div>
        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></div>
                <div class="user-details"><p class="user-name">@userName</p><p class="user-role">Student</p></div>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div class="dashboard-header">
            <h1>Your Profile</h1>
            <p>View your personal information and account credentials.</p>
        </div>

        @if (loading)
        {
            <div class="content-card"><div class="content-card-body">Loading...</div></div>
        }
        else if (student == null || user == null)
        {
            <div class="content-card"><div class="content-card-body">Profile not found.</div></div>
        }
        else
        {
            <div class="form-container">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-message">@errorMessage</div>
                }
                <div class="content-card">
                    <div class="content-card-header"><h3 class="content-card-title">Personal Info</h3></div>
                    <div class="content-card-body">
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">First Name</label>
                                <input class="form-input" @bind="student.FirstName" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Last Name</label>
                                <input class="form-input" @bind="student.LastName" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Email</label>
                                <input class="form-input" @bind="student.Email" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Username</label>
                                <input class="form-input" @bind="user.Username" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Contact Number</label>
                                <input class="form-input" @bind="student.ContactNumber" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Gender</label>
                                <select class="form-select" @bind="student.Gender">
                                    <option value="">Select</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                    <option>Other</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Date of Birth</label>
                                <input type="date" class="form-input" @bind-value="student.DateOfBirth" @bind-value:format="yyyy-MM-dd" />
                            </div>
                            <div class="form-group" style="grid-column: 1 / -1;">
                                <label class="form-label">Address</label>
                                <input class="form-input" @bind="student.Address" />
                            </div>
                        </div>
                        <div class="form-actions">
                            <button class="btn-primary" @onclick="SaveProfile" disabled="@saving">Save Changes</button>
                            <a class="btn-secondary" href="/students/profile">Cancel</a>
                        </div>
                    </div>
                </div>

                <div class="content-card" style="margin-top: 1rem;">
                    <div class="content-card-header"><h3 class="content-card-title">Change Password</h3></div>
                    <div class="content-card-body">
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Current Password</label>
                                <input type="password" class="form-input" @bind="currentPassword" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">New Password</label>
                                <input type="password" class="form-input" @bind="newPassword" />
                            </div>
                        </div>
                        <div class="form-actions">
                            <button class="btn-primary" @onclick="ChangePassword" disabled="@changingPassword">Update Password</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private Student? student;
    private UserAccount? user;
    private string userName = "";
    private bool loading = true;
    private bool saving = false;
    private string? errorMessage;

    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private bool changingPassword = false;

    protected override async Task OnInitializedAsync()
    {
        userName = AuthStateProvider.GetCurrentUsername() ?? "Student";
        var userId = AuthStateProvider.GetCurrentUserId();
        if (!userId.HasValue)
        {
            loading = false;
            return;
        }

        user = await AuthService.GetUserByIdAsync(userId.Value);
        var studentId = user?.ReferenceId ?? 0;
        if (studentId > 0)
        {
            student = await StudentService.GetStudentByIdAsync(studentId);
        }
        loading = false;
    }

    private async Task SaveProfile()
    {
        if (student == null || user == null) return;
        saving = true;
        StateHasChanged();
        try
        {
            // Update student extended fields
            await StudentService.UpdateStudentAsync(student);

            // Sync basic fields to user and update username/email
            user.FirstName = student.FirstName;
            user.LastName = student.LastName;
            user.Email = student.Email;
            user.Role = user.Role; // keep role
            await AuthService.UpdateUserAsync(user);

            Navigation.NavigateTo("/students/profile", true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
            StateHasChanged();
        }
    }

    private async Task ChangePassword()
    {
        if (user == null || string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword)) return;
        changingPassword = true;
        StateHasChanged();
        try
        {
            var ok = await AuthService.ChangePasswordAsync(user.UserId, currentPassword, newPassword);
            if (!ok)
            {
                errorMessage = "Invalid current password or unable to change password.";
            }
            else
            {
                currentPassword = string.Empty;
                newPassword = string.Empty;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            changingPassword = false;
            StateHasChanged();
        }
    }
}
