@page "/students/payment"
@using SmartEduERP.Components.Shared
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using Microsoft.AspNetCore.Components.Web
@using PaymentModel = SmartEduERP.Data.Models.Payment

@inject AuthStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject PaymentService PaymentService
@inject AuthService AuthService
@inject StudentService StudentService

<PageTitle>My Payments - SmartEduERP</PageTitle>

<style>
    .dashboard-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f5f5f5;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .sidebar { width: 260px; background: white; border-right: 1px solid #e5e5e5; position: fixed; height: 100vh; overflow-y: auto; display: flex; flex-direction: column; }
    .sidebar-header { padding: 1.25rem 1rem; border-bottom: 1px solid #e5e5e5; display: flex; align-items: center; gap: 0.75rem; }
    .sidebar-logo { width: 48px; height: 48px; }
    .sidebar-title { font-size: 1rem; font-weight: 600; margin: 0; color: #000; }
    .sidebar-subtitle { font-size: 0.75rem; color: #737373; margin: 0; }
    .sidebar-content { flex: 1; padding: 1rem 0; }
    .sidebar-section-label { padding: 0.5rem 1rem; font-size: 0.75rem; font-weight: 600; color: #737373; text-transform: uppercase; letter-spacing: 0.05em; }
    .sidebar-menu { list-style: none; padding: 0; margin: 0; }
    .sidebar-menu-item { padding: 0 0.75rem; }
    .sidebar-menu-button { width: 100%; padding: 0.625rem 0.75rem; background: none; border: none; display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; color: #404040; cursor: pointer; border-radius: 6px; transition: all 0.2s; text-decoration: none; }
    .sidebar-menu-button:hover { background: #f5f5f5; color: #000; }
    .sidebar-menu-button.active { background: #f0f0f0; color: #000; font-weight: 500; }
    .sidebar-menu-icon { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar-footer { padding: 1rem; border-top: 1px solid #e5e5e5; }
    .user-info { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem; margin-bottom: 0.75rem; }
    .user-avatar { width: 32px; height: 32px; background: #f0f0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; }
    .user-details { flex: 1; min-width: 0; }
    .user-name { font-size: 0.875rem; font-weight: 500; color: #000; margin: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .user-role { font-size: 0.75rem; color: #737373; margin: 0; }
    .logout-button { width: 100%; padding: 0.625rem; background: white; border: 1px solid #e5e5e5; border-radius: 6px; font-size: 0.875rem; color: #404040; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem; transition: all 0.2s; }
    .logout-button:hover { background: #f5f5f5; border-color: #d4d4d4; }

    .main-content { margin-left: 260px; flex: 1; padding: 1.5rem; }
    .dashboard-header { margin-bottom: 1.5rem; }
    .dashboard-header h1 { font-size: 1.75rem; font-weight: 600; color: #000; margin: 0 0 0.25rem 0; }
    .dashboard-header p { font-size: 0.9375rem; color: #737373; margin: 0; }

    .payment-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .summary-card { background: white; border: 1px solid #e5e5e5; border-radius: 8px; padding: 1.25rem; text-align: center; }
    .summary-value { font-size: 1.5rem; font-weight: 600; color: #000; margin: 0 0 0.25rem 0; }
    .summary-label { font-size: 0.875rem; color: #737373; margin: 0; }

    .content-card { background: white; border: 1px solid #e5e5e5; border-radius: 12px; overflow: hidden; margin-bottom: 1.5rem; }
    .content-card-header { padding: 1.25rem; border-bottom: 1px solid #e5e5e5; display: flex; justify-content: space-between; align-items: center; }
    .content-card-title { font-size: 1rem; font-weight: 600; color: #000; margin: 0; }
    .content-card-body { padding: 1.25rem; }

    .filter-bar { display: flex; gap: 1rem; align-items: center; }
    .filter-select { padding: 0.5rem; border: 1px solid #e5e5e5; border-radius: 4px; background: white; font-size: 0.875rem; }

    .table-responsive { overflow-x: auto; -webkit-overflow-scrolling: touch; }

    .payment-table { width: 100%; border-collapse: collapse; }
    .payment-table th { text-align: left; padding: 0.75rem; font-size: 0.75rem; font-weight: 600; color: #737373; border-bottom: 1px solid #e5e5e5; background: #fafafa; white-space: nowrap; }
    .payment-table td { padding: 0.75rem; font-size: 0.875rem; border-bottom: 1px solid #f5f5f5; vertical-align: top; }
    .payment-table tr:hover { background: #fafafa; }
    .payment-table tr:last-child td { border-bottom: none; }

    .payment-status { padding: 0; border-radius: 0; font-size: 0.75rem; font-weight: 500; white-space: nowrap; }
    .payment-status.paid { background: transparent; color: #166534; }
    .payment-status.pending { background: transparent; color: #92400e; }
    .payment-status.failed { background: transparent; color: #dc2626; }

    .payment-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .action-button { padding: 0.375rem 0.75rem; border: 1px solid #e5e5e5; border-radius: 4px; background: white; font-size: 0.75rem; color: #404040; cursor: pointer; transition: all 0.2s; text-decoration: none; }
    .action-button:hover { background: #f5f5f5; border-color: #d4d4d4; }
    .action-button.pay { border-color: #16a34a; color: #16a34a; }
    .action-button.pay:hover { background: #16a34a; color: white; }
    .action-button.details { border-color: #2563eb; color: #2563eb; }
    .action-button.details:hover { background: #2563eb; color: white; }

    .make-payment-section { background: white; border: 1px solid #e5e5e5; border-radius: 12px; padding: 1.5rem; margin-top: 2rem; }
    .payment-form { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; max-width: 500px; }
    .form-group { display: flex; flex-direction: column; }
    .form-group.full-width { grid-column: 1 / -1; }
    .form-label { font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem; color: #000; }
    .form-input, .form-select { padding: 0.625rem; border: 1px solid #e5e5e5; border-radius: 6px; font-size: 0.875rem; background: white; }
    .form-input:focus, .form-select:focus { outline: none; border-color: #000; }
    .submit-button { grid-column: 1 / -1; padding: 0.75rem 1.5rem; background: #000; color: white; border: none; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: background-color 0.2s; }
    .submit-button:hover { background: #404040; }
    .submit-button:disabled { background: #a3a3a3; cursor: not-allowed; }

    .loading-container { display: flex; justify-content: center; align-items: center; min-height: 400px; }
    .spinner { width: 40px; height: 40px; border: 3px solid #f5f5f5; border-top-color: #000; border-radius: 50%; animation: spin 0.8s linear infinite; }
    .empty-state { text-align: center; padding: 3rem 2rem; color: #737373; }
    .empty-state-icon { width: 48px; height: 48px; margin: 0 auto 1rem; color: #d4d4d4; }
    .empty-state-text { font-size: 1rem; font-weight: 500; margin: 0 0 0.5rem 0; color: #404040; }
    .empty-state-subtext { font-size: 0.875rem; margin: 0; color: #737373; }

    /* Details modal */
    .details-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1100; padding: 1rem; }
    .details-dialog { background: #fff; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.15); max-width: 520px; width: 100%; overflow: hidden; }
    .details-header { padding: 1rem 1.25rem; border-bottom: 1px solid #e5e5e5; }
    .details-header h3 { margin: 0; font-size: 1.125rem; font-weight: 600; color: #000; }
    .details-content { padding: 1rem 1.25rem; display: grid; grid-template-columns: 160px 1fr; row-gap: 0.75rem; column-gap: 1rem; }
    .details-label { font-size: 0.8125rem; color: #737373; }
    .details-value { font-size: 0.9375rem; color: #000; word-break: break-word; }
    .details-actions { padding: 1rem 1.25rem; border-top: 1px solid #e5e5e5; display: flex; justify-content: flex-end; gap: 0.5rem; }
    .btn-close { padding: 0.5rem 1rem; border: 1px solid #e5e5e5; border-radius: 6px; background: #fff; font-size: 0.875rem; cursor: pointer; }
    .btn-close:hover { background: #f5f5f5; }

    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="dashboard-wrapper">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo.png" alt="Logo" class="sidebar-logo" />
            <div>
                <h2 class="sidebar-title">Academic System</h2>
                <p class="sidebar-subtitle">Education Management</p>
            </div>

        </div>

        <div class="sidebar-content">
            <div class="sidebar-section-label">Student Menu</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item">
                    <a href="/student-dashboard" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/enrollments" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                        </svg>
                        <span>My Enrollments</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/viewgrades" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 11l3 3L22 4"></path>
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                        </svg>
                        <span>My Grades</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/students/payment" class="sidebar-menu-button active">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                        <span>Student Tuition Payments</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/students/schedule" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="16" y1="2" x2="16" y2="6"></line>
                            <line x1="8" y1="2" x2="8" y2="6"></line>
                            <line x1="3" y1="10" x2="21" y2="10"></line>
                        </svg>
                        <span>Class Schedule</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/students/profile" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                        <span>My Profile</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="user-details">
                    <p class="user-name">@userName</p>
                    <p class="user-role">Student</p>
                </div>
            </div>
            <button class="logout-button" @onclick="ShowLogoutConfirmation">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
