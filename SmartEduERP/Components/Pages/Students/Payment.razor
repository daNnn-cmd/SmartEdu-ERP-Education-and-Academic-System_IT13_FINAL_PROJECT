    <!-- Main Content -->
    <div class="main-content">
        <div class="dashboard-header">
            <h1>My Tuition Payments</h1>
            <p>View your payment history and make new tuition payments</p>
        </div>

        @if (loading)
        {
            <div class="loading-container">
                <div class="spinner"></div>
            </div>
        }
        else
        {
            <div class="payment-summary">
                <div class="summary-card">
                    <div class="summary-value">₱@totalPaid.ToString("N2")</div>
                    <div class="summary-label">Total Paid</div>
                </div>
                <div class="summary-card">
                    <div class="summary-value">₱@pendingAmount.ToString("N2")</div>
                    <div class="summary-label">Pending Payments</div>
                </div>
                <div class="summary-card">
                    <div class="summary-value">@completedPayments</div>
                    <div class="summary-label">Completed Payments</div>
                </div>
                <div class="summary-card">
                    <div class="summary-value">@pendingPayments</div>
                    <div class="summary-label">Pending</div>
                </div>
            </div>

            <div class="content-card">
                <div class="content-card-header">
                    <h3 class="content-card-title">Payment History</h3>
                    <div class="filter-bar">
                        <select class="filter-select" value="@selectedStatus" @onchange="(e => { selectedStatus = e.Value?.ToString() ?? string.Empty; ApplyFilters(); })">
                            <option value="">All Status</option>
                            <option value="Paid">Paid</option>
                            <option value="Pending">Pending</option>
                            <option value="Failed">Failed</option>
                        </select>
                        <select class="filter-select" value="@selectedYear" @onchange="(e => { selectedYear = e.Value?.ToString() ?? string.Empty; ApplyFilters(); })">
                            <option value="">All Years</option>
                            @foreach (var y in availableYears)
                            {
                                <option value="@y">@y</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="content-card-body">
                    @if (filteredPayments.Any())
                    {
                        <div class="table-responsive">
                            <table class="payment-table">
                                <thead>
                                    <tr>
                                        <th>Payment ID</th>
                                        <th>Date</th>
                                        <th>Amount</th>
                                        <th>Method</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in filteredPayments)
                                    {
                                        <tr>
                                            <td>@p.PaymentId</td>
                                            <td>@p.PaymentDate.ToString("MMM dd, yyyy")</td>
                                            <td>₱@p.Amount.ToString("N2")</td>
                                            <td>@p.PaymentMethod</td>
                                            <td>
                                                <span class="payment-status @GetStatusClass(p.PaymentStatus)">@p.PaymentStatus</span>
                                            </td>
                                            <td>
                                                <div class="payment-actions">
                                                    @if (string.Equals(p.PaymentStatus, "Pending", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <button class="action-button pay" disabled="@isProcessing" @onclick="(() => PayNow(p))">Pay Now</button>
                                                    }
                                                    <button class="action-button details" @onclick="(() => ViewDetails(p))">Details</button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">💳</div>
                            <p>No payments found.</p>
                        </div>
                    }
                </div>
            </div>

            
        }
    </div>
</div>

@if (showDetails && selectedPayment != null)
{
    <div class="details-overlay" @onclick="CloseDetails">
        <div class="details-dialog" @onclick:stopPropagation="true">
            <div class="details-header">
                <h3>Payment Details</h3>
            </div>
            <div class="details-content">
                <div class="details-label">Payment ID</div>
                <div class="details-value">@selectedPayment.PaymentId</div>

                <div class="details-label">Status</div>
                <div class="details-value">
                    <span class="payment-status @GetStatusClass(selectedPayment.PaymentStatus)">@selectedPayment.PaymentStatus</span>
                </div>

                <div class="details-label">Amount</div>
                <div class="details-value">₱@selectedPayment.Amount.ToString("N2")</div>

                <div class="details-label">Method</div>
                <div class="details-value">@selectedPayment.PaymentMethod</div>

                <div class="details-label">Payment Date</div>
                <div class="details-value">@selectedPayment.PaymentDate.ToString("MMM dd, yyyy hh:mm tt")</div>

                <div class="details-label">Created At</div>
                <div class="details-value">@selectedPayment.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</div>

                <div class="details-label">Updated At</div>
                <div class="details-value">@selectedPayment.UpdatedAt.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</div>

                <div class="details-label">Student ID</div>
                <div class="details-value">@selectedPayment.StudentId</div>
            </div>
            <div class="details-actions">
                <button type="button" class="btn-close" @onclick="CloseDetails">Close</button>
            </div>
        </div>
    </div>
}

<!-- Make Payment Confirmation Dialog -->
<ConfirmationDialog IsVisible="showMakePaymentConfirmation"
                    Title="Confirm Payment"
                    Message="@($"Confirm payment of ₱{newPaymentAmount:N2} via {newPaymentMethod}?")"
                    ConfirmText="Pay Now"
                    ProcessingText="Processing payment..."
                    Type="ConfirmationDialog.ConfirmationType.Warning"
                    IsProcessing="isProcessing"
                    OnConfirm="ConfirmMakePayment"
                    OnCancel="CancelMakePayment" />

<!-- Logout Confirmation Dialog -->
<ConfirmationDialog IsVisible="showLogoutConfirmation"
                    Title="Confirm Logout"
                    Message="Are you sure you want to log out? You will need to sign in again to access your dashboard."
                    ConfirmText="Log Out"
                    ProcessingText="Logging out..."
                    Type="ConfirmationDialog.ConfirmationType.Logout"
                    IsProcessing="isLoggingOut"
                    OnConfirm="ConfirmLogout"
                    OnCancel="CancelLogout" />

@code {
    private bool loading = true;
    private string userName = "";
    private int studentId = 0;
    private List<PaymentModel> payments = new();
    private List<PaymentModel> filteredPayments = new();

    // Summary statistics
    private decimal totalPaid = 0;
    private decimal pendingAmount = 0;
    private int completedPayments = 0;
    private int pendingPayments = 0;

    // Filters
    private string selectedStatus = "";
    private string selectedYear = "";
    private List<int> availableYears = new();

    // New payment inputs
    private decimal newPaymentAmount = 0;
    private string newPaymentMethod = string.Empty;
    private bool isProcessing = false;

    // Details modal
    private bool showDetails = false;
    private PaymentModel? selectedPayment;

    // Logout confirmation
    private bool showLogoutConfirmation = false;
    private bool isLoggingOut = false;

    // Make payment confirmation
    private bool showMakePaymentConfirmation = false;

    protected override async Task OnInitializedAsync()
    {
        userName = AuthStateProvider.GetCurrentUsername() ?? "Student";
        var userId = AuthStateProvider.GetCurrentUserId();
        if (userId.HasValue)
        {
            var user = await AuthService.GetUserByIdAsync(userId.Value);
            if (user?.ReferenceId != null)
            {
                studentId = user.ReferenceId.Value;
            }
            else if (!string.IsNullOrEmpty(user?.Email))
            {
                // Fallback: map by email then persist mapping
                var students = await StudentService.GetAllStudentsAsync();
                var match = students.FirstOrDefault(s => s.Email != null && s.Email.ToLower() == user.Email.ToLower());
                if (match != null)
                {
                    studentId = match.StudentId;
                    user.ReferenceId = studentId;
                    await AuthService.UpdateUserAsync(user);
                }
            }
        }

        await LoadPayments();
        loading = false;
    }

    private async Task LoadPayments()
    {
        if (studentId <= 0)
        {
            payments = new List<PaymentModel>();
            filteredPayments = payments;
            return;
        }

        payments = await PaymentService.GetPaymentsByStudentIdAsync(studentId);
        CalculateSummaryStatistics();
        InitializeFilters();
        ApplyFilters();
    }

    private void CalculateSummaryStatistics()
    {
        totalPaid = payments
            .Where(p => string.Equals(p.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase))
            .Sum(p => p.Amount);

        pendingAmount = payments
            .Where(p => string.Equals(p.PaymentStatus, "Pending", StringComparison.OrdinalIgnoreCase))
            .Sum(p => p.Amount);

        completedPayments = payments
            .Count(p => string.Equals(p.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase));

        pendingPayments = payments
            .Count(p => string.Equals(p.PaymentStatus, "Pending", StringComparison.OrdinalIgnoreCase));
    }

    private void InitializeFilters()
    {
        availableYears = payments
            .Select(p => p.PaymentDate.Year)
            .Distinct()
            .OrderByDescending(y => y)
            .ToList();
    }

    private void ApplyFilters()
    {
        IEnumerable<PaymentModel> query = payments;

        if (!string.IsNullOrEmpty(selectedStatus))
        {
            query = query.Where(p => string.Equals(p.PaymentStatus, selectedStatus, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrEmpty(selectedYear) && int.TryParse(selectedYear, out int year))
        {
            query = query.Where(p => p.PaymentDate.Year == year);
        }

        filteredPayments = query
            .OrderByDescending(p => p.PaymentDate)
            .ToList();
    }

    private string GetStatusClass(string? status)
    {
        return status?.ToLower() switch
        {
            "paid" => "paid",
            "pending" => "pending",
            "failed" => "failed",
            _ => "pending"
        };
    }

    private async Task PayNow(PaymentModel payment)
    {
        if (payment == null || payment.PaymentStatus == "Paid") return;
        isProcessing = true;
        StateHasChanged();

        // Mark as paid
        payment.PaymentStatus = "Paid";
        payment.PaymentDate = DateTime.Now;
        var currentUserId = AuthStateProvider.GetCurrentUserId();
        await PaymentService.UpdatePaymentAsync(payment, currentUserId);

        await LoadPayments();
        isProcessing = false;
        StateHasChanged();
    }

    private void ViewDetails(PaymentModel payment)
    {
        selectedPayment = payment;
        showDetails = true;
        StateHasChanged();
    }

    private void CloseDetails()
    {
        showDetails = false;
        selectedPayment = null;
        StateHasChanged();
    }

    private void ShowMakePaymentConfirmation()
    {
        if (studentId <= 0 || newPaymentAmount <= 0 || string.IsNullOrWhiteSpace(newPaymentMethod))
        {
            return;
        }
        showMakePaymentConfirmation = true;
    }

    private async Task ConfirmMakePayment()
    {
        showMakePaymentConfirmation = false;
        await ProcessPayment();
    }

    private void CancelMakePayment()
    {
        showMakePaymentConfirmation = false;
    }

    private async Task ProcessPayment()
    {
        if (studentId <= 0 || newPaymentAmount <= 0 || string.IsNullOrWhiteSpace(newPaymentMethod))
        {
            return;
        }

        isProcessing = true;
        StateHasChanged();

        var payment = new PaymentModel
        {
            StudentId = studentId,
            Amount = newPaymentAmount,
            PaymentMethod = newPaymentMethod,
            PaymentStatus = "Paid",
            PaymentDate = DateTime.Now,
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow
        };

        var currentUserId = AuthStateProvider.GetCurrentUserId();
        await PaymentService.CreatePaymentAsync(payment, currentUserId);

        // Reset form
        newPaymentAmount = 0;
        newPaymentMethod = string.Empty;

        await LoadPayments();

        isProcessing = false;
        StateHasChanged();
    }

    private void ShowLogoutConfirmation()
    {
        showLogoutConfirmation = true;
    }

    private async Task ConfirmLogout()
    {
        isLoggingOut = true;
        StateHasChanged();

        try
        {
            await AuthStateProvider.LogoutAsync();
            Navigation.NavigateTo("/", true);
        }
        catch
        {
            AuthStateProvider.MarkUserAsLoggedOut();
            Navigation.NavigateTo("/", true);
        }
        finally
        {
            isLoggingOut = false;
            showLogoutConfirmation = false;
        }
    }

    private void CancelLogout()
    {
        showLogoutConfirmation = false;
    }
}