@page "/admin/users"
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using SmartEduERP.Components.Shared
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthStateProvider AuthStateProvider
@inject IBidirectionalSyncService BidirectionalSyncService
@inject IGlobalSyncService GlobalSyncService
@inject IToastService ToastService

<PageTitle>User Management - SmartEduERP</PageTitle>

<style>
    
    .dashboard-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f5f5f5;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .sidebar {
        width: 260px;
        background: white;
        border-right: 1px solid #e5e5e5;
        position: fixed;
        height: 100vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #e5e5e5;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .sidebar-logo {
        width: 48px;
        height: 48px;
    }

    .sidebar-title {
        font-size: 1rem;
        font-weight: 600;
        margin: 0;
        color: #000;
    }

    .sidebar-subtitle {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .sidebar-content {
        flex: 1;
        padding: 1rem 0;
    }

    .sidebar-section-label {
        padding: 0.5rem 1rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: #737373;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-menu-item {
        padding: 0 0.75rem;
    }

    .sidebar-menu-button {
        width: 100%;
        padding: 0.625rem 0.75rem;
        background: none;
        border: none;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.2s;
        text-decoration: none;
    }

        .sidebar-menu-button:hover {
            background: #f5f5f5;
            color: #000;
        }

        .sidebar-menu-button.active {
            background: #f0f0f0;
            color: #000;
            font-weight: 500;
        }

    .sidebar-menu-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .sidebar-footer {
        padding: 1rem;
        border-top: 1px solid #e5e5e5;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        background: #f0f0f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
    }

    .user-details {
        flex: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 0.875rem;
        font-weight: 500;
        color: #000;
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .user-role {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .logout-button {
        width: 100%;
        padding: 0.625rem;
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

        .logout-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

    .main-content {
        margin-left: 260px;
        flex: 1;
        padding: 1.5rem;
    }

    .page-header {
        margin-bottom: 1.5rem;
    }

        .page-header h1 {
            font-size: 1.75rem;
            font-weight: 600;
            color: #000;
            margin: 0 0 0.25rem 0;
        }

        .page-header p {
            font-size: 0.9375rem;
            color: #737373;
            margin: 0;
        }

    .header-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .export-button, .add-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
    }

    .export-button {
        background: white;
        color: #404040;
    }

        .export-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .export-button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    .add-button {
        background: #000;
        color: white;
        border-color: #000;
    }

        .add-button:hover {
            background: #404040;
            border-color: #404040;
        }

    .content-card {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        overflow: hidden;
    }

    .content-card-header {
        padding: 1.25rem;
        border-bottom: 1px solid #e5e5e5;
    }

    .content-card-body {
        padding: 1.25rem;
    }

    .filters-grid {
        display: grid;
        grid-template-columns: 1fr auto auto auto auto;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .search-input, .filter-select, .page-size-select {
        padding: 0.625rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        background: white;
    }

        .search-input:focus, .filter-select:focus, .page-size-select:focus {
            outline: none;
            border-color: #000;
        }

    .filter-button {
        padding: 0.625rem 1rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        background: white;
        color: #404040;
        cursor: pointer;
        transition: all 0.2s;
    }

        .filter-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .filter-button.primary {
            background: #000;
            color: white;
            border-color: #000;
        }

            .filter-button.primary:hover {
                background: #404040;
                border-color: #404040;
            }

    .results-count {
        font-size: 0.75rem;
        color: #737373;
        margin-bottom: 1rem;
    }

    .users-table {
        width: 100%;
        border-collapse: collapse;
    }

        .users-table th {
            text-align: left;
            padding: 0.75rem;
            font-size: 0.75rem;
            font-weight: 500;
            color: #737373;
            border-bottom: 1px solid #e5e5e5;
            cursor: pointer;
            user-select: none;
        }

            .users-table th:hover {
                background: #f5f5f5;
            }

        .users-table td {
            padding: 0.75rem;
            font-size: 0.875rem;
            border-bottom: 1px solid #f5f5f5;
        }

        .users-table tr:last-child td {
            border-bottom: none;
        }

        .users-table tr:hover {
            background: #fafafa;
        }

    

    

    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .action-button {
        padding: 0.375rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 4px;
        font-size: 0.75rem;
        background: white;
        color: #404040;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
    }

        .action-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .action-button.edit {
            border-color: #3b82f6;
            color: #3b82f6;
        }

            .action-button.edit:hover {
                background: #3b82f6;
                color: white;
            }

        .action-button.archive {
            border-color: #f59e0b;
            color: #f59e0b;
        }

            .action-button.archive:hover {
                background: #f59e0b;
                color: white;
            }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1.5rem;
    }

    .pagination-button {
        padding: 0.5rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        background: white;
        color: #404040;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .pagination-button:hover:not(:disabled) {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .pagination-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .pagination-button.active {
            background: #000;
            color: white;
            border-color: #000;
        }

    .pagination-info {
        font-size: 0.75rem;
        color: #737373;
        margin: 0 1rem;
    }

    .loading-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 400px;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #f5f5f5;
        border-top-color: #000;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: #737373;
    }

    .empty-state-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    /* ✅ SYNC STYLES */
    .sync-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        padding: 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
    }

        .sync-status.syncing {
            background: #f0f9ff;
            color: #0369a1;
            border: 1px solid #bae6fd;
        }

        .sync-status.success {
            background: #f0fdf4;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .sync-status.error {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

    .sync-spinner {
        width: 12px;
        height: 12px;
        border: 2px solid transparent;
        border-top-color: currentColor;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .sync-badge {
    background: #dc2626;
    color: white;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    font-size: 0.7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -5px;
    left: 0px;   /* 👈 moved to left */
    right: auto;  /* 👈 disable right positioning */
}

    .sidebar-menu-item {
        position: relative;
    }

    /* Logout Confirmation Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        max-width: 400px;
        width: 90%;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }

    .modal-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .modal-icon {
        width: 40px;
        height: 40px;
        background: #fef3c7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #f59e0b;
    }

    .modal-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #000;
        margin: 0;
        font-family: Arial, sans-serif;
    }

    .modal-body {
        margin-bottom: 1.5rem;
    }

    .modal-text {
        font-size: 0.875rem;
        color: #737373;
        line-height: 1.5;
        margin: 0;
        font-family: Arial, sans-serif;
    }

    .modal-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }

    .modal-button {
        padding: 0.625rem 1.25rem;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
    }

    .modal-button-cancel {
        background: white;
        color: #404040;
        border: 1px solid #e5e5e5;
    }

        .modal-button-cancel:hover {
            background: #f5f5f5;
        }

    .modal-button-confirm {
        background: #000;
        color: white;
    }

        .modal-button-confirm:hover {
            background: #262626;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="dashboard-wrapper">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo.png" alt="Logo" class="sidebar-logo" />
            <div>
                <h2 class="sidebar-title">Smart EDU</h2>
                <p class="sidebar-subtitle">Academic System</p>
            </div>
        </div>

        <div class="sidebar-content">
            <div class="sidebar-section-label">Main Menu</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item">
                    <a href="/admin-dashboard" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/students" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                        <span>Student Management</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/teachers" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                            <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
                        </svg>
                        <span>Teacher Management</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/subjects" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                        </svg>
                        <span>Academic Management</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/admin/enrollment-approvals" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        </svg>
                        <span>Enrollment Approvals</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/payments" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                        <span>Student Tuition Payments</span>
                    </a>
                </li>
               
               
               
                <li class="sidebar-menu-item">
                    <a href="/admin/users" class="sidebar-menu-button active">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M22 11l-3-3m0 0l-3 3m3-3v7"></path>
                        </svg>
                        <span>Manage Users</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/audit-logs" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span>Audit Logs</span>
                    </NavLink>
                </li>
                

                <!-- ✅ SYNC TO CLOUD MENU ITEM -->
                <li class="sidebar-menu-item">
                    <button class="sidebar-menu-button" @onclick="GlobalSync" disabled="@isSyncing">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"></path>
                            <line x1="16" y1="5" x2="22" y2="5"></line>
                            <line x1="19" y1="2" x2="19" y2="8"></line>
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"></path>
                        </svg>
                        <span>Sync All to Cloud</span>
                        @if (isSyncing)
                        {
                            <div class="sync-spinner"></div>
                        }
                        @if (pendingSyncCount > 0 && !isSyncing)
                        {
                            <span class="sync-badge">@pendingSyncCount</span>
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(syncMessage))
                    {
                        <div class="sync-status @syncStatusClass">
                            @syncMessage
                        </div>
                    }
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="user-details">
                    <p class="user-name">@userName</p>
                    <p class="user-role">admin</p>
                </div>
            </div>
            <button class="logout-button" @onclick="ShowLogoutConfirmation">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                <span>Log Out</span>
            </button>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="page-header">
            <h1>User Management</h1>
            <p>Manage user accounts, roles, and permissions</p>
            <div class="header-actions">
                <a href="/admin/users/create" class="add-button">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    <span>Add New User</span>
                </a>
            </div>
        </div>

        @if (loading)
        {
            <div class="loading-container">
                <div class="spinner"></div>
            </div>
        }
        else
        {
            <div class="content-card">
                <div class="content-card-header">
                    <div class="filters-grid">
                        <input type="text"
                               class="search-input"
                               placeholder="Search by username or name..."
                               @bind="searchTerm"
                               @bind:event="oninput"
                               @onkeyup="HandleSearch" />

                        <select class="filter-select" @bind="filterRole" @bind:after="ApplyFilters">
                            <option value="">All Roles</option>
                            <option value="Admin">Admin</option>
                            <option value="Teacher">Teacher</option>
                            <option value="Student">Student</option>
                            <option value="HR">HR</option>
                            <option value="Accounting">Accounting</option>
                        </select>

                        <button class="filter-button primary" @onclick="ApplyFilters">
                            Search
                        </button>

                        <button class="filter-button" @onclick="ClearFilters">
                            Clear
                        </button>

                        <select class="page-size-select" @bind="pageSize" @bind:after="LoadUsers">
                            <option value="10">10 per page</option>
                            <option value="25">25 per page</option>
                            <option value="50">50 per page</option>
                            <option value="100">100 per page</option>
                        </select>
                    </div>

                    <div class="results-count">
                        Showing @filteredUsers.Count of @totalRecords users
                    </div>
                </div>

                <div class="content-card-body">
                    @if (filteredUsers.Any())
                    {
                        <div class="table-responsive">
                            <table class="users-table">
                                <thead>
                                    <tr>
                                        <th @onclick='() => SortBy("Username")'>
                                            Username @GetSortIcon("Username")
                                        </th>
                                        <th @onclick='() => SortBy("FirstName")'>
                                            Full Name @GetSortIcon("FirstName")
                                        </th>
                                        <th>Email</th>
                                        <th @onclick='() => SortBy("Role")'>
                                            Role @GetSortIcon("Role")
                                        </th>
                                       
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in paginatedUsers)
                                    {
                                        <tr>
                                            <td><strong>@user.Username</strong></td>
                                            <td>@user.FirstName @user.LastName</td>
                                            <td>@user.Email</td>
                                            <td>
                                                <span class="role-badge @(user.Role?.ToLower())">@user.Role</span>
                                            </td>
                                            
                                            <td>@(user.IsDeleted ? "Archived" : "Active")</td>
                                            <td>
                                                <div class="action-buttons">
                                                    <a href="/admin/users/edit/@user.UserId" class="action-button edit">
                                                        Edit
                                                    </a>
                                                    <button class="action-button archive"
                                                            @onclick="() => ShowArchiveConfirmation(user.UserId, user.Username)">
                                                        Archive
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        @if (totalPages > 1)
                        {
                            <div class="pagination">
                                <button class="pagination-button"
                                        @onclick="() => ChangePage(currentPage - 1)"
                                        disabled="@(currentPage == 1)">
                                    Previous
                                </button>

                                <span class="pagination-info">
                                    Page @currentPage of @totalPages
                                </span>

                                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                                {
                                    var pageNum = i;
                                    <button class="pagination-button @(currentPage == pageNum ? "active" : "")"
                                            @onclick="() => ChangePage(pageNum)">
                                        @pageNum
                                    </button>
                                }

                                <button class="pagination-button"
                                        @onclick="() => ChangePage(currentPage + 1)"
                                        disabled="@(currentPage == totalPages)">
                                    Next
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">👥</div>
                            <h3>No Users Found</h3>
                            <p>
                                @if (string.IsNullOrEmpty(searchTerm) && string.IsNullOrEmpty(filterRole))
                                {
                                    <text>No users have been added yet. Click "Add New User" to get started.</text>
                                }
                                else
                                {
                                    <text>No users match your search criteria. Try adjusting your filters.</text>
                                }
                            </p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Confirmation Dialogs -->
    <ConfirmationDialog IsVisible="showLogoutConfirmation" Title="Confirm Logout"
                        Message="Are you sure you want to log out? You will need to sign in again to access your account."
                        ConfirmText="Log Out" ProcessingText="Logging out..." Type="@ConfirmationDialog.ConfirmationType.Logout"
                        IsProcessing="isLoggingOut" OnConfirm="ConfirmLogout" OnCancel="HideLogoutConfirmation" />

    <!-- Archive Confirmation Dialog -->
    <ConfirmationDialog IsVisible="showArchiveConfirmation"
                        Title="Archive User"
                        Message="@archiveConfirmationMessage"
                        ConfirmText="Archive"
                        ProcessingText="Archiving..."
                        Type="ConfirmationDialog.ConfirmationType.Warning"
                        IsProcessing="isArchiving"
                        OnConfirm="ConfirmArchive"
                        OnCancel="CancelArchive" />
</div>

@code {
    private List<UserAccount> users = new();
    private List<UserAccount> filteredUsers = new();
    private List<UserAccount> paginatedUsers = new();
    private string searchTerm = "";
    private string filterRole = "";
    private string sortColumn = "UserId";
    private bool sortAscending = false;
    private bool loading = true;
    private bool showLogoutConfirmation = false;
    private bool isLoggingOut = false;
    private string userName = "";
    private int currentPage = 1;
    private int pageSize = 25;
    private int totalRecords = 0;
    private int totalPages => (int)Math.Ceiling((double)totalRecords / pageSize);

    // Archive confirmation
    private bool showArchiveConfirmation = false;
    private bool isArchiving = false;
    private int userToArchiveId = 0;
    private string archiveConfirmationMessage = "";

    // ✅ SYNC PROPERTIES
    private bool isSyncing = false;
    private string syncMessage = "";
    private string syncStatusClass = "";
    private int pendingSyncCount = 0;
    private System.Threading.Timer? syncStatusTimer;

    protected override async Task OnInitializedAsync()
    {
        userName = AuthStateProvider.GetCurrentUsername() ?? "Admin";
        await Task.WhenAll(
            LoadUsers(),
            LoadPendingSyncCount()
        );
        
        // ✅ ADD: Start periodic sync status updates
        syncStatusTimer = new System.Threading.Timer(async _ =>
        {
            await LoadPendingSyncCount();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromMinutes(1));
    }

    private async Task LoadUsers()
    {
        loading = true;
        users = await AuthService.GetAllUsersAsync();
        totalRecords = users.Count;
        ApplyFiltersAndSort();
        loading = false;
    }

    private void ApplyFiltersAndSort()
    {
        var query = users.AsEnumerable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var search = searchTerm.ToLower();
            query = query.Where(u =>
                (u.Username?.ToLower().Contains(search) ?? false) ||
                (u.FirstName?.ToLower().Contains(search) ?? false) ||
                (u.LastName?.ToLower().Contains(search) ?? false));
        }

        // Apply role filter
        if (!string.IsNullOrEmpty(filterRole))
        {
            query = query.Where(u => u.Role == filterRole);
        }

        totalRecords = query.Count();

        // Apply sorting
        query = sortColumn switch
        {
            "Username" => sortAscending
                ? query.OrderBy(u => u.Username)
                : query.OrderByDescending(u => u.Username),
            "FirstName" => sortAscending
                ? query.OrderBy(u => u.FirstName)
                : query.OrderByDescending(u => u.FirstName),
            "Role" => sortAscending
                ? query.OrderBy(u => u.Role)
                : query.OrderByDescending(u => u.Role),
            "UserId" => sortAscending
                ? query.OrderBy(u => u.UserId)
                : query.OrderByDescending(u => u.UserId),
            _ => sortAscending
                ? query.OrderBy(u => u.UserId)
                : query.OrderByDescending(u => u.UserId)
        };

        // Apply pagination
        filteredUsers = query.ToList();
        paginatedUsers = filteredUsers
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private void UpdatePagination()
    {
        paginatedUsers = filteredUsers
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private async Task HandleSearch()
    {
        currentPage = 1;
        ApplyFiltersAndSort();
        await Task.CompletedTask;
    }

    private async Task ApplyFilters()
    {
        currentPage = 1;
        ApplyFiltersAndSort();
        await Task.CompletedTask;
    }

    private async Task ClearFilters()
    {
        searchTerm = "";
        filterRole = "";
        sortColumn = "UserId";
        sortAscending = false;
        currentPage = 1;
        ApplyFiltersAndSort();
        await Task.CompletedTask;
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        ApplyFiltersAndSort();
    }

    private string GetSortIcon(string column)
    {
        if (sortColumn != column)
            return "";
        return sortAscending ? " ▲" : " ▼";
    }

    private void ChangePage(int page)
    {
        if (page < 1 || page > totalPages)
            return;
        currentPage = page;
        UpdatePagination();
    }

    private void ShowArchiveConfirmation(int userId, string username)
    {
        userToArchiveId = userId;
        archiveConfirmationMessage = $"Are you sure you want to archive the user '{username}'? This action will move the user to archived records.";
        showArchiveConfirmation = true;
    }

    private async Task ConfirmArchive()
    {
        isArchiving = true;
        StateHasChanged();

        try
        {
            await AuthService.DeleteUserAsync(userToArchiveId);
            await LoadUsers();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error archiving user: {ex.Message}");
        }
        finally
        {
            isArchiving = false;
            showArchiveConfirmation = false;
            userToArchiveId = 0;
            archiveConfirmationMessage = "";
        }
    }

    private void CancelArchive()
    {
        showArchiveConfirmation = false;
        userToArchiveId = 0;
        archiveConfirmationMessage = "";
    }

    private string GetRoleClass(string? role)
    {
        return role?.ToLower() switch
        {
            "admin" => "admin",
            "teacher" => "teacher",
            "student" => "student",
            _ => ""
        };
    }

    // Logout functionality
    private void ShowLogoutConfirmation()
    {
        showLogoutConfirmation = true;
        StateHasChanged();
    }

    private void HideLogoutConfirmation()
    {
        showLogoutConfirmation = false;
        isLoggingOut = false;
        StateHasChanged();
    }

    private async Task ConfirmLogout()
    {
        isLoggingOut = true;
        StateHasChanged();

        try
        {
            // Try to use proper logout if available
            if (AuthStateProvider is AuthStateProvider authProvider && authProvider.GetType().GetMethod("LogoutAsync") != null)
            {
                await ((dynamic)AuthStateProvider).LogoutAsync();
            }
            else
            {
                AuthStateProvider.MarkUserAsLoggedOut();
            }

            Navigation.NavigateTo("/", true);
        }
        catch
        {
            // Fallback to simple logout
            AuthStateProvider.MarkUserAsLoggedOut();
            Navigation.NavigateTo("/", true);
        }
    }

    // ✅ SYNC METHODS
    private async Task GlobalSync()
    {
        if (isSyncing) return;

        isSyncing = true;
        syncMessage = "🔄 Syncing bidirectionally (Local ↔ Cloud)...";
        syncStatusClass = "syncing";
        StateHasChanged();

        try
        {
            var result = await BidirectionalSyncService.SyncAsync();

            if (result.Success)
            {
                syncMessage = $"✅ Bidirectional sync successful! +{result.RecordsAdded} ~{result.RecordsUpdated} -{result.RecordsDeleted}";
                syncStatusClass = "success";
                ToastService.ShowSuccess($"Sync completed: {result.RecordsAdded} added, {result.RecordsUpdated} updated");
                
                await LoadPendingSyncCount();
            }
            else
            {
                var errorMsg = result.Errors.Any() ? string.Join(", ", result.Errors) : "Unknown error";
                syncMessage = $"❌ Sync failed: {errorMsg}";
                syncStatusClass = "error";
                ToastService.ShowWarning($"Sync failed: {errorMsg}");
            }
        }
        catch (Exception ex)
        {
            syncMessage = $"❌ Sync error: {ex.Message}";
            syncStatusClass = "error";
            ToastService.ShowError($"Sync error: {ex.Message}");
        }
        finally
        {
            isSyncing = false;
            StateHasChanged();

            _ = Task.Run(async () =>
            {
                await Task.Delay(5000);
                syncMessage = "";
                syncStatusClass = "";
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task LoadPendingSyncCount()
    {
        try
        {
            pendingSyncCount = await GlobalSyncService.GetPendingSyncCountAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading sync count: {ex.Message}");
        }
    }
}