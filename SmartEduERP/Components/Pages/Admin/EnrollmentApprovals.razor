@page "/admin/enrollment-approvals"
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using SmartEduERP.Components.Shared
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject EnrollmentService EnrollmentService
@inject AuthStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject SyncTimerService SyncService
@inject IToastService ToastService
@inject IGlobalSyncService GlobalSyncService
@inject IBidirectionalSyncService BidirectionalSyncService
@implements IDisposable

<style>
    .dashboard-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f5f5f5;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .sidebar {
        width: 260px;
        background: white;
        border-right: 1px solid #e5e5e5;
        position: fixed;
        height: 100vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #e5e5e5;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .sidebar-logo {
        width: 48px;
        height: 48px;
    }

    .sidebar-title {
        font-size: 1rem;
        font-weight: 600;
        margin: 0;
        color: #000;
    }

    .sidebar-subtitle {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .sidebar-content {
        flex: 1;
        padding: 1rem 0;
    }

    .sidebar-section-label {
        padding: 0.5rem 1rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: #737373;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-menu-item {
        padding: 0 0.75rem;
        position: relative;
    }

    .sidebar-menu-button {
        width: 100%;
        padding: 0.625rem 0.75rem;
        background: none;
        border: none;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.2s;
        text-decoration: none;
    }

        .sidebar-menu-button:hover {
            background: #f5f5f5;
            color: #000;
        }

        .sidebar-menu-button.active {
            background: #f0f0f0;
            color: #000;
            font-weight: 500;
        }

    .sidebar-menu-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .sidebar-footer {
        padding: 1rem;
        border-top: 1px solid #e5e5e5;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        background: #f0f0f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
    }

    .user-details {
        flex: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 0.875rem;
        font-weight: 500;
        color: #000;
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .user-role {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .logout-button {
        width: 100%;
        padding: 0.625rem;
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

        .logout-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

    .main-content {
        margin-left: 260px;
        flex: 1;
        padding: 1.5rem;
    }

    .dashboard-header {
        margin-bottom: 1.5rem;
    }

        .dashboard-header h1 {
            font-size: 1.75rem;
            font-weight: 600;
            color: #000;
            margin: 0 0 0.25rem 0;
        }

        .dashboard-header p {
            font-size: 0.9375rem;
            color: #737373;
            margin: 0;
        }

    .content-card {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        overflow: hidden;
    }

    .content-card-header {
        padding: 1.25rem;
        border-bottom: 1px solid #e5e5e5;
    }

    .content-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: #000;
        margin: 0;
    }

    .content-card-body {
        padding: 1.25rem;
    }

    .filters-grid {
        display: grid;
        grid-template-columns: 1fr auto auto auto auto;
        gap: 0.75rem;
        margin-top: 1rem;
        margin-bottom: 1rem;
        align-items: center;
    }

    .search-input,
    .filter-select,
    .page-size-select {
        padding: 0.625rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        background: white;
    }

        .search-input:focus,
        .filter-select:focus,
        .page-size-select:focus {
            outline: none;
            border-color: #000;
        }

    .filter-button {
        padding: 0.625rem 1rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        background: white;
        color: #404040;
        cursor: pointer;
        transition: all 0.2s;
    }

        .filter-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .filter-button.primary {
            background: #000;
            color: white;
            border-color: #000;
        }

            .filter-button.primary:hover {
                background: #404040;
                border-color: #404040;
            }

    .loading-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 280px;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #f5f5f5;
        border-top-color: #000;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .enrollments-table {
        width: 100%;
        border-collapse: collapse;
    }

        .enrollments-table th {
            text-align: left;
            padding: 0.75rem;
            font-size: 0.75rem;
            font-weight: 600;
            color: #737373;
            border-bottom: 1px solid #e5e5e5;
            background: #fafafa;
            white-space: nowrap;
        }

        .enrollments-table td {
            padding: 0.75rem;
            font-size: 0.875rem;
            border-bottom: 1px solid #f5f5f5;
            vertical-align: top;
        }

        .enrollments-table tr:last-child td {
            border-bottom: none;
        }

        .enrollments-table tr:hover {
            background: #fafafa;
        }

    .enrollment-status {
        padding: 0;
        border-radius: 0;
        font-size: 0.75rem;
        font-weight: 500;
        white-space: nowrap;
    }

        .enrollment-status.pending {
            background: transparent;
            color: #92400e;
        }

        .enrollment-status.approved {
            background: transparent;
            color: #166534;
        }

        .enrollment-status.rejected {
            background: transparent;
            color: #991b1b;
        }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .action-button {
        padding: 0.375rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 4px;
        font-size: 0.75rem;
        background: white;
        color: #404040;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
    }

        .action-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .action-button.approve {
            border-color: #16a34a;
            color: #16a34a;
        }

            .action-button.approve:hover {
                background: #16a34a;
                color: white;
            }

        .action-button.reject {
            border-color: #dc2626;
            color: #dc2626;
        }

            .action-button.reject:hover {
                background: #dc2626;
                color: white;
            }

        .action-button.view {
            border-color: #2563eb;
            color: #2563eb;
        }

            .action-button.view:hover {
                background: #2563eb;
                color: white;
            }

    .btn-secondary {
        padding: 0.625rem 1rem;
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

        .btn-secondary:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
            color: #404040;
            text-decoration: none;
        }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1.5rem;
    }

    .pagination-button {
        padding: 0.5rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        background: white;
        color: #404040;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .pagination-button:hover:not(:disabled) {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .pagination-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .pagination-button.active {
            background: #000;
            color: white;
            border-color: #000;
        }

    .pagination-info {
        font-size: 0.75rem;
        color: #737373;
        margin: 0 1rem;
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        max-width: 420px;
        width: 90%;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }

    .modal-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #000;
        margin: 0;
    }

    .modal-body {
        margin-top: 1rem;
        margin-bottom: 1.5rem;
    }

    .modal-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }

    .modal-button {
        padding: 0.625rem 1.25rem;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
    }

    .modal-button-cancel {
        background: white;
        color: #404040;
        border: 1px solid #e5e5e5;
    }

        .modal-button-cancel:hover {
            background: #f5f5f5;
        }

    .modal-button-confirm {
        background: #000;
        color: white;
    }

        .modal-button-confirm:hover {
            background: #262626;
        }

    .form-label {
        display: block;
        font-weight: 600;
        color: #737373;
        font-size: 0.75rem;
        margin-bottom: 0.375rem;
    }

    .form-input {
        width: 100%;
        padding: 0.625rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        box-sizing: border-box;
    }

        .form-input:focus {
            outline: none;
            border-color: #000;
        }

        .empty-state h3 {
            font-size: 1rem;
            font-weight: 600;
            color: #404040;
            margin: 0 0 0.5rem 0;
        }

        .empty-state p {
            font-size: 0.875rem;
            margin: 0;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .sync-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        padding: 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
    }

        .sync-status.syncing {
            background: #f0f9ff;
            color: #0369a1;
            border: 1px solid #bae6fd;
        }

        .sync-status.success {
            background: #f0fdf4;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .sync-status.error {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

    .sync-spinner {
        width: 12px;
        height: 12px;
        border: 2px solid transparent;
        border-top-color: currentColor;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .sync-badge {
        background: #dc2626;
        color: white;
        border-radius: 50%;
        width: 18px;
        height: 18px;
        font-size: 0.7rem;
        display: flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        top: -5px;
        left: 0px;
        right: auto;
    }
</style>

<div class="dashboard-wrapper">
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo.png" alt="Logo" class="sidebar-logo" />
            <div>
                <h2 class="sidebar-title">Smart EDU</h2>
                <p class="sidebar-subtitle">Academic System</p>
            </div>
        </div>

        <div class="sidebar-content">
            <div class="sidebar-section-label">Main Menu</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item">
                    <a href="/admin-dashboard" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="sidebar-menu-item">
                    <a href="/students" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                        <span>Student Management</span>
                    </a>
                </li>

                <li class="sidebar-menu-item">
                    <a href="/teachers" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                            <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
                        </svg>
                        <span>Teacher Management</span>
                    </a>
                </li>

                <li class="sidebar-menu-item">
                    <a href="/subjects" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                        </svg>
                        <span>Academic Management</span>
                    </a>
                </li>

                <li class="sidebar-menu-item">
                    <a href="/admin/enrollment-approvals" class="sidebar-menu-button active">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        </svg>
                        <span>Enrollment Approvals</span>
                    </a>
                </li>

                <li class="sidebar-menu-item">
                    <a href="/payments" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                        <span>Student Tuition Payments</span>
                    </a>
                </li>

               

           
                <li class="sidebar-menu-item">
                    <a href="/admin/users" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M22 11l-3-3m0 0l-3 3m3-3v7"></path>
                        </svg>
                        <span>Manage Users</span>
                    </a>
                </li>

                <li class="sidebar-menu-item">
                    <a href="/audit-logs" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span>Audit Logs</span>
                    </a>
                </li>
                <!-- ✅ UPDATED: Enhanced Global Sync Menu Item -->
                <li class="sidebar-menu-item">
                    <button class="sidebar-menu-button" @onclick="GlobalSync" disabled="@isSyncing">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"></path>
                            <line x1="16" y1="5" x2="22" y2="5"></line>
                            <line x1="19" y1="2" x2="19" y2="8"></line>
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"></path>
                        </svg>
                        <span>Sync All to Cloud</span>
                        @if (isSyncing)
                        {
                            <div class="sync-spinner"></div>
                        }
                        @if (pendingSyncCount > 0 && !isSyncing)
                        {
                            <span class="sync-badge">@pendingSyncCount</span>
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(syncMessage))
                    {
                        <div class="sync-status @syncStatusClass">
                            @syncMessage
                        </div>
                    }
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="user-details">
                    <p class="user-name">@userName</p>
                    <p class="user-role">admin</p>
                </div>
            </div>
            <button class="logout-button" @onclick="ShowLogoutConfirmation">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                <span>Log Out</span>
            </button>
        </div>
    </div>

    <div class="main-content">
        <div class="dashboard-header">
            <h1>Enrollment Approvals</h1>
            <p>Approve or reject pending enrollments.</p>
        </div>

        @if (!isAdmin)
        {
            <div class="content-card">
                <div class="content-card-body">
                    <div class="empty-state">
                        <h3>Access Denied</h3>
                        <p>This page is only accessible to administrators.</p>
                    </div>
                </div>
            </div>
        }
        else if (loading)
        {
            <div class="loading-container">
                <div class="spinner"></div>
            </div>
        }
        else
        {
            <div class="content-card">
                <div class="content-card-header">
                    <h3 class="content-card-title">Enrollments</h3>
                    <div class="filters-grid">
                        <input type="text" class="search-input" placeholder="Search student or subject..." @bind="searchTerm"
                               @bind:event="oninput" @onkeyup="HandleSearch" />

                        <select class="filter-select" @bind="statusFilter" @bind:after="ApplyFiltersAsync">
                            <option value="">All Status</option>
                            <option value="Pending">Pending</option>
                            <option value="Approved">Approved</option>
                            <option value="Rejected">Rejected</option>
                        </select>

                        <button class="filter-button primary" @onclick="ApplyFilters">
                            Search
                        </button>

                        <button class="filter-button" @onclick="ClearFilters">
                            Clear
                        </button>

                        <select class="page-size-select" @bind="pageSize" @bind:after="OnPageSizeChanged">
                            <option value="10">10 per page</option>
                            <option value="25">25 per page</option>
                            <option value="50">50 per page</option>
                            <option value="100">100 per page</option>
                        </select>
                    </div>

                    <div class="results-count">
                        Showing @pagedEnrollments.Count of @totalRecords enrollments
                    </div>
                </div>
                <div class="content-card-body">
                    @if (pagedEnrollments.Any())
                    {
                        <div class="table-responsive">
                            <table class="enrollments-table">
                                <thead>
                                    <tr>
                                        <th>Student</th>
                                        <th>Subject</th>
                                        <th>Academic Year</th>
                                        <th>Semester</th>
                                        <th>Status</th>
                                        <th>Created At</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var enrollment in pagedEnrollments)
                                    {
                                        <tr>
                                            <td>@(enrollment.Student != null ? $"{enrollment.Student.FirstName} {enrollment.Student.LastName}" : "-")</td>
                                            <td>@(enrollment.Subject != null ? $"{enrollment.Subject.SubjectCode} - {enrollment.Subject.SubjectName}" : "-")</td>
                                            <td>@enrollment.AcademicYear</td>
                                            <td>@enrollment.Semester</td>
                                            <td>
                                                <span class="enrollment-status @GetEnrollmentStatusClass(enrollment.EnrollmentStatus)">@GetEnrollmentStatusText(enrollment.EnrollmentStatus)</span>
                                            </td>
                                            <td>@enrollment.CreatedAt.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                <div class="action-buttons">
                                                    @if (IsPending(enrollment.EnrollmentStatus))
                                                    {
                                                        <button class="action-button approve" @onclick="() => ShowApproveModal(enrollment.EnrollmentId)">Approve</button>
                                                        <button class="action-button reject" @onclick="() => ShowRejectModal(enrollment.EnrollmentId)">Reject</button>
                                                    }
                                                    else
                                                    {
                                                        <button class="action-button view" @onclick="() => ShowDetailsModal(enrollment.EnrollmentId)">View</button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (totalPages > 1)
                        {
                            <div class="pagination">
                                <button class="pagination-button" @onclick="() => ChangePage(currentPage - 1)" disabled="@(currentPage == 1)">
                                    Previous
                                </button>

                                <span class="pagination-info">
                                    Page @currentPage of @totalPages
                                </span>

                                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                                {
                                    var pageNum = i;
                                    <button class="pagination-button @(currentPage == pageNum ? "active" : "")" @onclick="() => ChangePage(pageNum)">
                                        @pageNum
                                    </button>
                                }

                                <button class="pagination-button" @onclick="() => ChangePage(currentPage + 1)" disabled="@(currentPage == totalPages)">
                                    Next
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <h3>No Enrollments Found</h3>
                            <p>No enrollments are available.</p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@if (showApproveModal)
{
    <div class="modal-overlay" @onclick="HideApproveModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3 class="modal-title">Approve Enrollment</h3>
            <div class="modal-body">
                <label class="form-label">Approved By</label>
                <input class="form-input" type="text" @bind="approveByInput" placeholder="Enter name" />
            </div>
            <div class="modal-actions">
                <button class="modal-button modal-button-cancel" @onclick="HideApproveModal">Cancel</button>
                <button class="modal-button modal-button-confirm" @onclick="ConfirmApprove" disabled="@processingApproval">
                    @(processingApproval ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}

@if (showDetailsModal && selectedEnrollment != null)
{
    <div class="modal-overlay" @onclick="HideDetailsModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3 class="modal-title">Enrollment Details</h3>
            <div class="modal-body">
                <div>
                    <label class="form-label">Status</label>
                    <div>@GetEnrollmentStatusText(selectedEnrollment.EnrollmentStatus)</div>
                </div>

                <div style="height: 0.75rem;"></div>

                @if (string.Equals(GetEnrollmentStatusText(selectedEnrollment.EnrollmentStatus), "Approved", StringComparison.OrdinalIgnoreCase))
                {
                    <label class="form-label">Approved By</label>
                    <div>@(string.IsNullOrWhiteSpace(selectedEnrollment.ApprovedBy) ? "-" : selectedEnrollment.ApprovedBy)</div>

                    <div style="height: 0.5rem;"></div>
                    <label class="form-label">Approved At</label>
                    <div>@(selectedEnrollment.ApprovedAt.HasValue ? selectedEnrollment.ApprovedAt.Value.ToString("MMM dd, yyyy hh:mm tt") : "-")</div>
                }
                else if (string.Equals(GetEnrollmentStatusText(selectedEnrollment.EnrollmentStatus), "Rejected", StringComparison.OrdinalIgnoreCase))
                {
                    <label class="form-label">Rejected By</label>
                    <div>@(string.IsNullOrWhiteSpace(selectedEnrollment.RejectedBy) ? "-" : selectedEnrollment.RejectedBy)</div>

                    <div style="height: 0.5rem;"></div>
                    <label class="form-label">Rejected At</label>
                    <div>@(selectedEnrollment.RejectedAt.HasValue ? selectedEnrollment.RejectedAt.Value.ToString("MMM dd, yyyy hh:mm tt") : "-")</div>

                    <div style="height: 0.5rem;"></div>
                    <label class="form-label">Reason</label>
                    <div>@(string.IsNullOrWhiteSpace(selectedEnrollment.RejectionReason) ? "-" : selectedEnrollment.RejectionReason)</div>
                }
                else
                {
                    <label class="form-label">Processed By</label>
                    <div>-</div>
                }
            </div>
            <div class="modal-actions">
                <button class="modal-button modal-button-cancel" @onclick="HideDetailsModal">Close</button>
            </div>
        </div>
    </div>
}

@if (showRejectModal)
{
    <div class="modal-overlay" @onclick="HideRejectModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <h3 class="modal-title">Reject Enrollment</h3>
            <div class="modal-body">
                <label class="form-label">Rejected By</label>
                <input class="form-input" type="text" @bind="rejectByInput" placeholder="Enter name" />

                <div style="height: 0.75rem;"></div>
                <label class="form-label">Reason </label>
                <input class="form-input" type="text" @bind="rejectReasonInput" placeholder="Enter reason" />
            </div>
            <div class="modal-actions">
                <button class="modal-button modal-button-cancel" @onclick="HideRejectModal">Cancel</button>
                <button class="modal-button modal-button-confirm" @onclick="ConfirmReject" disabled="@processingApproval">
                    @(processingApproval ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}

<ConfirmationDialog IsVisible="showLogoutConfirmation"
                    Title="Confirm Logout"
                    Message="Are you sure you want to log out? You will need to sign in again to access your dashboard."
                    ConfirmText="Log Out"
                    ProcessingText="Logging out..."
                    Type="ConfirmationDialog.ConfirmationType.Logout"
                    IsProcessing="isLoggingOut"
                    OnConfirm="ConfirmLogout"
                    OnCancel="CancelLogout" />

@code {
    private bool isAdmin = false;
    private bool loading = true;

    private string userName = "Admin";

    private bool showLogoutConfirmation = false;
    private bool isLoggingOut = false;

    private List<Enrollment> enrollments = new();
    private List<Enrollment> filteredEnrollments = new();
    private List<Enrollment> pagedEnrollments = new();
    private int currentPage = 1;
    private int pageSize = 25;
    private int totalRecords = 0;
    private int totalPages => (int)Math.Ceiling((double)totalRecords / pageSize);

    private string searchTerm = "";
    private string statusFilter = "";

    private bool showApproveModal = false;
    private bool showRejectModal = false;
    private bool showDetailsModal = false;
    private Enrollment? selectedEnrollment;
    private int enrollmentIdToProcess;
    private string approveByInput = "";
    private string rejectByInput = "";
    private string rejectReasonInput = "";
    private bool processingApproval = false;

    private bool isSyncing = false;
    private string syncMessage = "";
    private string syncStatusClass = "";
    private int pendingSyncCount = 0;
    private System.Threading.Timer? syncStatusTimer;

    protected override async Task OnInitializedAsync()
    {
        userName = AuthStateProvider.GetCurrentUsername() ?? "Admin";
        var role = AuthStateProvider.GetCurrentUserRole();
        isAdmin = !string.IsNullOrWhiteSpace(role) && role.Equals("Admin", StringComparison.OrdinalIgnoreCase);
        await LoadEnrollments();

        if (isAdmin)
        {
            await LoadPendingSyncCount();
            syncStatusTimer = new System.Threading.Timer(async _ =>
            {
                await LoadPendingSyncCount();
                await InvokeAsync(StateHasChanged);
            }, null, TimeSpan.Zero, TimeSpan.FromMinutes(1));
        }
    }

    private async Task GlobalSync()
    {
        if (!isAdmin) return;
        if (isSyncing) return;

        isSyncing = true;
        syncMessage = "🔄 Syncing bidirectionally (Local ↔ Cloud)...";
        syncStatusClass = "syncing";
        StateHasChanged();

        try
        {
            var result = await BidirectionalSyncService.SyncAsync();

            if (result.Success)
            {
                syncMessage = $"✅ Bidirectional sync successful! +{result.RecordsAdded} ~{result.RecordsUpdated} -{result.RecordsDeleted}";
                syncStatusClass = "success";
                ToastService.ShowSuccess($"Sync completed: {result.RecordsAdded} added, {result.RecordsUpdated} updated");

                await LoadPendingSyncCount();
            }
            else
            {
                var errorMsg = result.Errors.Any() ? string.Join(", ", result.Errors) : "Unknown error";
                syncMessage = $"❌ Sync failed: {errorMsg}";
                syncStatusClass = "error";
                ToastService.ShowWarning($"Sync failed: {errorMsg}");
            }
        }
        catch (Exception ex)
        {
            syncMessage = $"❌ Sync error: {ex.Message}";
            syncStatusClass = "error";
            ToastService.ShowError($"Sync error: {ex.Message}");
        }
        finally
        {
            isSyncing = false;
            StateHasChanged();

            _ = Task.Run(async () =>
            {
                await Task.Delay(5000);
                syncMessage = "";
                syncStatusClass = "";
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task LoadPendingSyncCount()
    {
        try
        {
            pendingSyncCount = await GlobalSyncService.GetPendingSyncCountAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading sync count: {ex.Message}");
        }
    }

    public void Dispose()
    {
        syncStatusTimer?.Dispose();
    }

    private void HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            ApplyFilters();
        }
    }

    private Task ApplyFiltersAsync()
    {
        ApplyFilters();
        return Task.CompletedTask;
    }

    private void ApplyFilters()
    {
        currentPage = 1;

        filteredEnrollments = enrollments
            .Where(MatchesFilters)
            .ToList();

        totalRecords = filteredEnrollments.Count;
        UpdatePagedEnrollments();
        StateHasChanged();
    }

    private void ClearFilters()
    {
        searchTerm = "";
        statusFilter = "";
        ApplyFilters();
    }

    private bool MatchesFilters(Enrollment e)
    {
        if (!string.IsNullOrWhiteSpace(statusFilter))
        {
            var status = GetEnrollmentStatusText(e.EnrollmentStatus);
            if (!status.Equals(statusFilter, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }
        }

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.Trim();

            var studentName = e.Student != null ? $"{e.Student.FirstName} {e.Student.LastName}" : "";
            var subjectName = e.Subject?.SubjectName ?? "";
            var subjectCode = e.Subject?.SubjectCode ?? "";

            var haystack = $"{studentName} {subjectName} {subjectCode} {e.AcademicYear} {e.Semester}";
            if (!haystack.Contains(term, StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }
        }

        return true;
    }

    private static bool IsPending(string? status) => string.IsNullOrWhiteSpace(status) || status.Equals("Pending", StringComparison.OrdinalIgnoreCase);

    private static string GetEnrollmentStatusText(string? status) => string.IsNullOrWhiteSpace(status) ? "Pending" : status;

    private static string GetEnrollmentStatusClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return "pending";
        return status.ToLower() switch
        {
            "approved" => "approved",
            "pending" => "pending",
            "rejected" => "rejected",
            _ => "pending"
        };
    }

    private void ShowLogoutConfirmation()
    {
        showLogoutConfirmation = true;
    }

    private async Task ConfirmLogout()
    {
        isLoggingOut = true;
        StateHasChanged();

        try
        {
            await AuthStateProvider.LogoutAsync();
            Navigation.NavigateTo("/", true);
        }
        catch
        {
            AuthStateProvider.MarkUserAsLoggedOut();
            Navigation.NavigateTo("/", true);
        }
        finally
        {
            isLoggingOut = false;
            showLogoutConfirmation = false;
        }
    }

    private void CancelLogout()
    {
        showLogoutConfirmation = false;
    }

    private async Task LoadEnrollments()
    {
        loading = true;
        StateHasChanged();

        if (!isAdmin)
        {
            enrollments = new List<Enrollment>();
            filteredEnrollments = new List<Enrollment>();
            pagedEnrollments = new List<Enrollment>();
            totalRecords = 0;
            loading = false;
            StateHasChanged();
            return;
        }

        var all = await EnrollmentService.GetAllEnrollmentsAsync();
        enrollments = all
            .OrderByDescending(e => e.CreatedAt)
            .ToList();

        ApplyFilters();

        loading = false;
        StateHasChanged();
    }

    private async Task Reload()
    {
        await LoadEnrollments();
    }

    private void UpdatePagedEnrollments()
    {
        if (pageSize <= 0) pageSize = 25;
        if (currentPage <= 0) currentPage = 1;

        if (totalPages > 0 && currentPage > totalPages) currentPage = totalPages;

        pagedEnrollments = filteredEnrollments
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
    }

    private Task OnPageSizeChanged()
    {
        currentPage = 1;
        totalRecords = filteredEnrollments.Count;
        UpdatePagedEnrollments();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ChangePage(int page)
    {
        if (page < 1) page = 1;
        if (page > totalPages) page = totalPages;

        currentPage = page;
        UpdatePagedEnrollments();
        StateHasChanged();
    }

    private void ShowApproveModal(int enrollmentId)
    {
        enrollmentIdToProcess = enrollmentId;
        approveByInput = "";
        showApproveModal = true;
        StateHasChanged();
    }

    private void HideApproveModal()
    {
        showApproveModal = false;
        enrollmentIdToProcess = 0;
        approveByInput = "";
        StateHasChanged();
    }

    private void ShowRejectModal(int enrollmentId)
    {
        enrollmentIdToProcess = enrollmentId;
        rejectByInput = "";
        rejectReasonInput = "";
        showRejectModal = true;
        StateHasChanged();
    }

    private void HideRejectModal()
    {
        showRejectModal = false;
        enrollmentIdToProcess = 0;
        rejectByInput = "";
        rejectReasonInput = "";
        StateHasChanged();
    }

    private void ShowDetailsModal(int enrollmentId)
    {
        selectedEnrollment = enrollments.FirstOrDefault(e => e.EnrollmentId == enrollmentId);
        showDetailsModal = selectedEnrollment != null;
        StateHasChanged();
    }

    private void HideDetailsModal()
    {
        showDetailsModal = false;
        selectedEnrollment = null;
        StateHasChanged();
    }

    private async Task ConfirmApprove()
    {
        if (processingApproval) return;

        if (string.IsNullOrWhiteSpace(approveByInput))
        {
            await JS.InvokeVoidAsync("alert", "Please enter who approved this enrollment.");
            return;
        }

        var userId = AuthStateProvider.GetCurrentUserId();
        if (!userId.HasValue)
        {
            await JS.InvokeVoidAsync("alert", "Unable to identify current user.");
            return;
        }

        processingApproval = true;
        StateHasChanged();

        try
        {
            var ok = await EnrollmentService.ApproveEnrollmentAsync(enrollmentIdToProcess, userId.Value, approveByInput);
            if (!ok)
            {
                await JS.InvokeVoidAsync("alert", "Failed to approve enrollment. It may have already been processed.");
                return;
            }

            await LoadEnrollments();
            HideApproveModal();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error approving enrollment: {ex.Message}");
        }
        finally
        {
            processingApproval = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmReject()
    {
        if (processingApproval) return;

        if (string.IsNullOrWhiteSpace(rejectByInput))
        {
            await JS.InvokeVoidAsync("alert", "Please enter who rejected this enrollment.");
            return;
        }

        var userId = AuthStateProvider.GetCurrentUserId();
        if (!userId.HasValue)
        {
            await JS.InvokeVoidAsync("alert", "Unable to identify current user.");
            return;
        }

        processingApproval = true;
        StateHasChanged();

        try
        {
            var ok = await EnrollmentService.RejectEnrollmentAsync(enrollmentIdToProcess, userId.Value, rejectByInput, rejectReasonInput);
            if (!ok)
            {
                await JS.InvokeVoidAsync("alert", "Failed to reject enrollment. It may have already been processed.");
                return;
            }

            await LoadEnrollments();
            HideRejectModal();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error rejecting enrollment: {ex.Message}");
        }
        finally
        {
            processingApproval = false;
            StateHasChanged();
        }
    }
}
