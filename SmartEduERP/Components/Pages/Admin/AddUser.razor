@page "/admin/users/create"
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using SmartEduERP.Components.Shared
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthService AuthService
@inject StudentService StudentService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthStateProvider AuthStateProvider
@inject TeacherService TeacherService
@inject IBidirectionalSyncService BidirectionalSyncService
@inject IGlobalSyncService GlobalSyncService
@inject IToastService ToastService

<PageTitle>Create User - SmartEduERP</PageTitle>

<style>

    .dashboard-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f5f5f5;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .sidebar {
        width: 260px;
        background: white;
        border-right: 1px solid #e5e5e5;
        position: fixed;
        height: 100vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #e5e5e5;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .sidebar-logo {
        width: 48px;
        height: 48px;
    }

    .sidebar-title {
        font-size: 1rem;
        font-weight: 600;
        margin: 0;
        color: #000;
    }

    .sidebar-subtitle {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .sidebar-content {
        flex: 1;
        padding: 1rem 0;
    }

    .sidebar-section-label {
        padding: 0.5rem 1rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: #737373;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-menu-item {
        padding: 0 0.75rem;
    }

    .sidebar-menu-button {
        width: 100%;
        padding: 0.625rem 0.75rem;
        background: none;
        border: none;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.2s;
        text-decoration: none;
    }

        .sidebar-menu-button:hover {
            background: #f5f5f5;
            color: #000;
        }

        .sidebar-menu-button.active {
            background: #f0f0f0;
            color: #000;
            font-weight: 500;
        }

    .sidebar-menu-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .sidebar-footer {
        padding: 1rem;
        border-top: 1px solid #e5e5e5;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        background: #f0f0f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
    }

    .user-details {
        flex: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 0.875rem;
        font-weight: 500;
        color: #000;
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .user-role {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .logout-button {
        width: 100%;
        padding: 0.625rem;
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

        .logout-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

    .main-content {
        margin-left: 260px;
        flex: 1;
        padding: 1.5rem;
    }

    .page-header {
        margin-bottom: 1.5rem;
    }

        .page-header h1 {
            font-size: 1.75rem;
            font-weight: 600;
            color: #000;
            margin: 0 0 0.25rem 0;
        }

        .page-header p {
            font-size: 0.9375rem;
            color: #737373;
            margin: 0;
        }

    .header-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .back-button, .add-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
    }

    .back-button {
        background: white;
        color: #404040;
    }

        .back-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

    .add-button {
        background: #000;
        color: white;
        border-color: #000;
    }

        .add-button:hover {
            background: #404040;
            border-color: #404040;
        }

        .add-button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            background: #737373;
            border-color: #737373;
        }

    .content-card {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        overflow: hidden;
        max-width: 800px;
    }

    .content-card-header {
        padding: 1.25rem;
        border-bottom: 1px solid #e5e5e5;
    }

        .content-card-header h2 {
            font-size: 1.25rem;
            font-weight: 600;
            color: #000;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .content-card-body {
        padding: 1.25rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .form-full-width {
        grid-column: 1 / -1;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-label {
        font-size: 0.875rem;
        font-weight: 500;
        color: #000;
    }

        .form-label .required {
            color: #dc2626;
        }

    .form-input, .form-select {
        padding: 0.625rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        background: white;
        transition: all 0.2s;
    }

        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: #000;
            box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
        }

        .form-input.invalid, .form-select.invalid {
            border-color: #dc2626;
        }

    .form-hint {
        font-size: 0.75rem;
        color: #737373;
        margin-top: 0.25rem;
    }

    .form-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid #f5f5f5;
    }

    .alert {
        padding: 0.75rem 1rem;
        border-radius: 6px;
        font-size: 0.875rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
    }

    .alert-danger {
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #dc2626;
    }

    .alert-success {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        color: #166534;
    }

    .alert-close {
        background: none;
        border: none;
        color: inherit;
        cursor: pointer;
        padding: 0;
        margin-left: auto;
    }

    .success-card {
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 1.5rem;
    }

        .success-card h3 {
            font-size: 1rem;
            font-weight: 600;
            color: #166534;
            margin: 0 0 1rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .success-info {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.5rem 1rem;
        margin-bottom: 1.5rem;
    }

        .success-info strong {
            font-weight: 600;
            color: #000;
        }

    .success-actions {
        display: flex;
        gap: 0.75rem;
    }

    .spinner {
        width: 16px;
        height: 16px;
        border: 2px solid transparent;
        border-top-color: currentColor;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    .validation-message {
        font-size: 0.75rem;
        color: #dc2626;
        margin-top: 0.25rem;
    }

    /* ✅ SYNC STYLES */
    .sync-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        padding: 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
    }

        .sync-status.syncing {
            background: #f0f9ff;
            color: #0369a1;
            border: 1px solid #bae6fd;
        }

        .sync-status.success {
            background: #f0fdf4;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .sync-status.error {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

    .sync-spinner {
        width: 12px;
        height: 12px;
        border: 2px solid transparent;
        border-top-color: currentColor;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .sync-badge {
    background: #dc2626;
    color: white;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    font-size: 0.7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -5px;
    left: 0px;   /* 👈 moved to left */
    right: auto;  /* 👈 disable right positioning */
}

    .sidebar-menu-item {
        position: relative;
    }

    /* Logout Confirmation Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        max-width: 400px;
        width: 90%;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }

    .modal-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .modal-icon {
        width: 40px;
        height: 40px;
        background: #fef3c7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #f59e0b;
    }

    .modal-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #000;
        margin: 0;
        font-family: Arial, sans-serif;
    }

    .modal-body {
        margin-bottom: 1.5rem;
    }

    .modal-text {
        font-size: 0.875rem;
        color: #737373;
        line-height: 1.5;
        margin: 0;
        font-family: Arial, sans-serif;
    }

    .modal-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }

    .modal-button {
        padding: 0.625rem 1.25rem;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
    }

    .modal-button-cancel {
        background: white;
        color: #404040;
        border: 1px solid #e5e5e5;
    }

        .modal-button-cancel:hover {
            background: #f5f5f5;
        }

    .modal-button-confirm {
        background: #000;
        color: white;
    }

        .modal-button-confirm:hover {
            background: #262626;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="dashboard-wrapper">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo.png" alt="Logo" class="sidebar-logo" />
            <div>
                <h2 class="sidebar-title">Smart EDU</h2>
                <p class="sidebar-subtitle">Academic System</p>
            </div>
        </div>

        <div class="sidebar-content">
            <div class="sidebar-section-label">Main Menu</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item">
                    <a href="/admin-dashboard" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/students" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                        <span>Student Management</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/teachers" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                            <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
                        </svg>
                        <span>Teacher Management</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/subjects" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                        </svg>
                        <span>Academic Management</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/admin/enrollment-approvals" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        </svg>
                        <span>Enrollment Approvals</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/payments" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                        <span>Student Tuition Payments</span>
                    </a>
                </li>
               
               
                
                <li class="sidebar-menu-item">
                    <a href="/admin/users" class="sidebar-menu-button active">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M22 11l-3-3m0 0l-3 3m3-3v7"></path>
                        </svg>
                        <span>Manage Users</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/audit-logs" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span>Audit Logs</span>
                    </NavLink>
                </li>
               

                <!-- ✅ SYNC TO CLOUD MENU ITEM -->
                <li class="sidebar-menu-item">
                    <button class="sidebar-menu-button" @onclick="GlobalSync" disabled="@isSyncing">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"></path>
                            <line x1="16" y1="5" x2="22" y2="5"></line>
                            <line x1="19" y1="2" x2="19" y2="8"></line>
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"></path>
                        </svg>
                        <span>Sync All to Cloud</span>
                        @if (isSyncing)
                        {
                            <div class="sync-spinner"></div>
                        }
                        @if (pendingSyncCount > 0 && !isSyncing)
                        {
                            <span class="sync-badge">@pendingSyncCount</span>
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(syncMessage))
                    {
                        <div class="sync-status @syncStatusClass">
                            @syncMessage
                        </div>
                    }
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="user-details">
                    <p class="user-name">@userName</p>
                    <p class="user-role">admin</p>
                </div>
            </div>
            <button class="logout-button" @onclick="ShowLogoutConfirmation">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                <span>Log Out</span>
            </button>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="page-header">
            <h1>Create User</h1>
            <p>Add a new user account to the system</p>
        </div>

        <div class="content-card">
            <div class="content-card-header">
                <h2>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="8.5" cy="7" r="4"></circle>
                        <line x1="20" y1="8" x2="20" y2="14"></line>
                        <line x1="23" y1="11" x2="17" y2="11"></line>
                    </svg>
                    Add New User
                </h2>
            </div>

            <div class="content-card-body">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                        <span>@errorMessage</span>
                        <button class="alert-close" @onclick="() => errorMessage = null">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                            </svg>
                        </button>
                    </div>
                }

                <EditForm Model="@userModel" OnValidSubmit="@HandleAddUser">
                    <DataAnnotationsValidator />

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">
                                First Name <span class="required">*</span>
                            </label>
                            <InputText class="form-input" @bind-Value="userModel.FirstName" placeholder="Enter first name" />
                            <ValidationMessage For="@(() => userModel.FirstName)" class="validation-message" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                Last Name <span class="required">*</span>
                            </label>
                            <InputText class="form-input" @bind-Value="userModel.LastName" placeholder="Enter last name" />
                            <ValidationMessage For="@(() => userModel.LastName)" class="validation-message" />
                        </div>

                        <div class="form-group form-full-width">
                            <label class="form-label">
                                Email Address <span class="required">*</span>
                            </label>
                            <InputText class="form-input" @bind-Value="userModel.Email" placeholder="Enter email address" />
                            <ValidationMessage For="@(() => userModel.Email)" class="validation-message" />
                            
                        </div>

                        <div class="form-group form-full-width">
                            <label class="form-label">
                                Username <span class="required">*</span>
                            </label>
                            <InputText class="form-input" @bind-Value="userModel.Username" placeholder="Choose a username" />
                            <ValidationMessage For="@(() => userModel.Username)" class="validation-message" />
                            <div class="form-hint">This will be used for login</div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                Password <span class="required">*</span>
                            </label>
                            <InputText type="password" class="form-input" @bind-Value="userModel.Password" placeholder="Minimum 12 characters" />
                            <ValidationMessage For="@(() => userModel.Password)" class="validation-message" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                Confirm Password <span class="required">*</span>
                            </label>
                            <InputText type="password" class="form-input" @bind-Value="userModel.ConfirmPassword" placeholder="Re-enter password" />
                            <ValidationMessage For="@(() => userModel.ConfirmPassword)" class="validation-message" />
                        </div>

                        <div class="form-group form-full-width">
                            <label class="form-label">
                                Role <span class="required">*</span>
                            </label>
                            <InputSelect class="form-select" @bind-Value="userModel.Role">
                                <option value="">-- Select Role --</option>
                                <option value="Admin">Admin - Full system access</option>
                                <option value="Teacher">Teacher - Manage grades & students</option>
                                <option value="Student">Student - View grades & enrollments</option>
                                <option value="HR">HR - Human Resources</option>
                                <option value="Accounting">Accounting - Teacher Income</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => userModel.Role)" class="validation-message" />
                        </div>


                        <div class="form-group">
                            <label class="form-label">
                                Email Confirmation
                            </label>
                            <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.625rem 0;">
                                <InputCheckbox @bind-Value="userModel.IsEmailConfirmed" />
                                <span style="font-size: 0.875rem;">Email confirmed</span>
                            </div>
                            <div class="form-hint">Check if email has been verified</div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="add-button" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <div class="spinner"></div>
                                <span>Creating User...</span>
                            }
                            else
                            {
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20 6L9 17l-5-5"></path>
                                </svg>
                                <span>Create User</span>
                            }
                        </button>
                        <a href="/admin/users" class="back-button">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M19 12H5M12 19l-7-7 7-7"></path>
                            </svg>
                            <span>Cancel</span>
                        </a>
                    </div>
                </EditForm>
            </div>
        </div>

    </div>

    <!-- Confirmation Dialog -->
    <ConfirmationDialog IsVisible="showLogoutConfirmation" Title="Confirm Logout"
                        Message="Are you sure you want to log out? You will need to sign in again to access your account."
                        ConfirmText="Log Out" ProcessingText="Logging out..." Type="@ConfirmationDialog.ConfirmationType.Logout"
                        IsProcessing="isLoggingOut" OnConfirm="ConfirmLogout" OnCancel="HideLogoutConfirmation" />
</div>

@code {
    private UserModel userModel = new();
    private string? errorMessage;
    private bool isLoading = false;
    private bool showLogoutConfirmation = false;
    private bool isLoggingOut = false;
    private string userName = "";

    // ✅ SYNC PROPERTIES
    private bool isSyncing = false;
    private string syncMessage = "";
    private string syncStatusClass = "";
    private int pendingSyncCount = 0;
    private System.Threading.Timer? syncStatusTimer;

    protected override async Task OnInitializedAsync()
    {
        userName = AuthStateProvider.GetCurrentUsername() ?? "Admin";
        // ✅ ADD: Start periodic sync status updates
        await LoadPendingSyncCount();
        syncStatusTimer = new System.Threading.Timer(async _ =>
        {
            await LoadPendingSyncCount();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromMinutes(1));
    }

    private async Task HandleAddUser()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            Console.WriteLine("🚀 Starting user creation process...");

            // Validate passwords match
            if (userModel.Password != userModel.ConfirmPassword)
            {
                errorMessage = "Passwords do not match.";
                isLoading = false;
                return;
            }

            // Check if username exists
            if (await AuthService.UsernameExistsAsync(userModel.Username))
            {
                errorMessage = "The username is already in use. Please choose a different username.";
                isLoading = false;
                return;
            }

            // Check if email exists
            if (await AuthService.EmailExistsAsync(userModel.Email))
            {
                errorMessage = "The email address is already registered. Please use a different email address.";
                isLoading = false;
                return;
            }

            // Create new user
            var user = new UserAccount
            {
                FirstName = userModel.FirstName,
                LastName = userModel.LastName,
                Username = userModel.Username,
                Email = userModel.Email,
                Role = userModel.Role,
                IsEmailConfirmed = userModel.IsEmailConfirmed,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };

            Console.WriteLine($"👤 Creating user account: {user.Username} with role: {user.Role}");

            // This will automatically create teacher/student records via AuthService.RegisterAsync
            await AuthService.RegisterAsync(user, userModel.Password);
            Console.WriteLine($"✅ User account created successfully with ID: {user.UserId}");

            // Redirect to UserList
            Navigation.NavigateTo("/admin/users");
        }
        catch (Exception ex)
        {
            errorMessage = $"An error occurred while creating the user: {ex.Message}";
            Console.WriteLine($"❌ ERROR: {ex.Message}");
            Console.WriteLine($"❌ Stack trace: {ex.StackTrace}");
        }
        finally
        {
            isLoading = false;
        }
    }



    // Logout functionality
    private void ShowLogoutConfirmation()
    {
        showLogoutConfirmation = true;
        StateHasChanged();
    }

    private void HideLogoutConfirmation()
    {
        showLogoutConfirmation = false;
        isLoggingOut = false;
        StateHasChanged();
    }

    private async Task ConfirmLogout()
    {
        isLoggingOut = true;
        StateHasChanged();

        try
        {
            // Try to use proper logout if available
            if (AuthStateProvider is AuthStateProvider authProvider && authProvider.GetType().GetMethod("LogoutAsync") != null)
            {
                await ((dynamic)AuthStateProvider).LogoutAsync();
            }
            else
            {
                AuthStateProvider.MarkUserAsLoggedOut();
            }

            Navigation.NavigateTo("/", true);
        }
        catch
        {
            // Fallback to simple logout
            AuthStateProvider.MarkUserAsLoggedOut();
            Navigation.NavigateTo("/", true);
        }
    }

    // ✅ SYNC METHODS
    private async Task GlobalSync()
    {
        if (isSyncing) return;

        isSyncing = true;
        syncMessage = "🔄 Syncing bidirectionally (Local ↔ Cloud)...";
        syncStatusClass = "syncing";
        StateHasChanged();

        try
        {
            var result = await BidirectionalSyncService.SyncAsync();

            if (result.Success)
            {
                syncMessage = $"✅ Bidirectional sync successful! +{result.RecordsAdded} ~{result.RecordsUpdated} -{result.RecordsDeleted}";
                syncStatusClass = "success";
                ToastService.ShowSuccess($"Sync completed: {result.RecordsAdded} added, {result.RecordsUpdated} updated");
                
                await LoadPendingSyncCount();
            }
            else
            {
                var errorMsg = result.Errors.Any() ? string.Join(", ", result.Errors) : "Unknown error";
                syncMessage = $"❌ Sync failed: {errorMsg}";
                syncStatusClass = "error";
                ToastService.ShowWarning($"Sync failed: {errorMsg}");
            }
        }
        catch (Exception ex)
        {
            syncMessage = $"❌ Sync error: {ex.Message}";
            syncStatusClass = "error";
            ToastService.ShowError($"Sync error: {ex.Message}");
        }
        finally
        {
            isSyncing = false;
            StateHasChanged();

            _ = Task.Run(async () =>
            {
                await Task.Delay(5000);
                syncMessage = "";
                syncStatusClass = "";
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task LoadPendingSyncCount()
    {
        try
        {
            pendingSyncCount = await GlobalSyncService.GetPendingSyncCountAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading sync count: {ex.Message}");
        }
    }

    public class UserModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "First name is required")]
        [System.ComponentModel.DataAnnotations.MaxLength(100, ErrorMessage = "First name cannot exceed 100 characters")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[A-Z][a-zA-Z\s\-']*$", ErrorMessage = "First name must start with a capital letter and contain only letters, spaces, hyphens, and apostrophes.")]
        public string FirstName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Last name is required")]
        [System.ComponentModel.DataAnnotations.MaxLength(100, ErrorMessage = "Last name cannot exceed 100 characters")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[A-Z][a-zA-Z\s\-']*$", ErrorMessage = "Last name must start with a capital letter and contain only letters, spaces, hyphens, and apostrophes.")]
        public string LastName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required")]
        [System.ComponentModel.DataAnnotations.MinLength(3, ErrorMessage = "Username must be at least 3 characters")]
        [System.ComponentModel.DataAnnotations.MaxLength(50, ErrorMessage = "Username cannot exceed 50 characters")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[A-Za-z][A-Za-z0-9_.-]{2,49}$", ErrorMessage = "Username must start with a letter and can contain letters, numbers, dots, hyphens, and underscores.")]
        public string Username { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email address")]
        [System.ComponentModel.DataAnnotations.MaxLength(255, ErrorMessage = "Email cannot exceed 255 characters")]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        [System.ComponentModel.DataAnnotations.MinLength(12, ErrorMessage = "Password must be at least 12 characters")]
        [System.ComponentModel.DataAnnotations.MaxLength(255, ErrorMessage = "Password cannot exceed 255 characters")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^[A-Za-z0-9!@#$%^&*()\-_=+\[\]{};:,./?]+$", ErrorMessage = "Password contains invalid characters.")]
        public string Password { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please confirm password")]
        [System.ComponentModel.DataAnnotations.Compare("Password", ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please select a role")]
        [System.ComponentModel.DataAnnotations.MaxLength(50, ErrorMessage = "Role cannot exceed 50 characters")]
        [System.ComponentModel.DataAnnotations.RegularExpression(@"^(Admin|Teacher|Student|HR|Accounting)$", ErrorMessage = "Invalid role selected.")]
        public string Role { get; set; } = "";

        public bool IsEmailConfirmed { get; set; } = false;
    }
}