@page "/hr/performance"
@using System.Linq
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using SmartEduERP.Components.Pages.Hr
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,HR")]
@inject HrService HrService

<PageTitle>HR - Performance</PageTitle>

<style>
    .hr-page { padding: 1.5rem; }
    .hr-title { font-size: 1.6rem; font-weight: 600; margin-bottom: 0.25rem; }
    .hr-subtitle { font-size: 0.95rem; color: #6b7280; margin-bottom: 1.25rem; }
    .hr-card { background: #fff; border-radius: 12px; border: 1px solid #e5e5e5; padding: 1.25rem; margin-bottom: 1.25rem; }
    .hr-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem 1rem; }
    .hr-label { font-size: 0.8rem; font-weight: 500; color: #4b5563; margin-bottom: 0.2rem; }
    .hr-input, .hr-select, .hr-textarea { width: 100%; border-radius: 6px; border: 1px solid #d1d5db; padding: 0.45rem 0.6rem; font-size: 0.85rem; }
    .hr-textarea { min-height: 80px; }
    .hr-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .hr-table th { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #e5e5e5; font-weight: 500; color: #6b7280; background: #f9fafb; }
    .hr-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #f3f4f6; }
    .hr-btn-primary { border-radius: 8px; border: none; padding: 0.45rem 0.9rem; background: #2563eb; color: #fff; font-size: 0.85rem; cursor: pointer; }
    .hr-table-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; gap: 0.5rem; }
    .hr-pagination { display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-top: 1rem; }
    .hr-pagination-button { border-radius: 6px; border: 1px solid #d1d5db; padding: 0.35rem 0.7rem; background: #fff; font-size: 0.8rem; cursor: pointer; }
    .hr-pagination-button.active { background: #111827; color: #fff; border-color: #111827; }
    .hr-pagination-button:disabled { opacity: 0.5; cursor: not-allowed; }
    .hr-pagination-info { font-size: 0.8rem; color: #6b7280; margin: 0 0.75rem; }
    .hr-page-size-select { width: auto; min-width: 120px; }
</style>

<HrLayout>
<div class="hr-page">
    <div class="hr-title">Performance Reviews</div>
    <div class="hr-subtitle">Record basic evaluations for employees.</div>

    <div class="hr-card">
        <div class="hr-grid">
            <div>
                <div class="hr-label">Employee</div>
                <select class="hr-select" @bind="newReview.EmployeeId">
                    <option value="0">Select employee...</option>
                    @foreach (var e in employees)
                    {
                        <option value="@e.EmployeeId">@e.FirstName @e.LastName</option>
                    }
                </select>
            </div>
            <div>
                <div class="hr-label">Review Date</div>
                <InputDate DateTimeFormat="yyyy-MM-dd" class="hr-input" @bind-Value="newReview.ReviewDate" />
            </div>
            <div>
                <div class="hr-label">Reviewer</div>
                <InputText class="hr-input" @bind-Value="newReview.ReviewerName" />
            </div>
            <div>
                <div class="hr-label">Score (1-5)</div>
                <InputNumber class="hr-input" @bind-Value="newReview.Score" />
            </div>
        </div>
        <div class="hr-grid" style="margin-top:0.75rem;">
            <div>
                <div class="hr-label">Period Start</div>
                <InputDate DateTimeFormat="yyyy-MM-dd" class="hr-input" @bind-Value="newReview.PeriodStart" />
            </div>
            <div>
                <div class="hr-label">Period End</div>
                <InputDate DateTimeFormat="yyyy-MM-dd" class="hr-input" @bind-Value="newReview.PeriodEnd" />
            </div>
        </div>
        <div style="margin-top:0.75rem;">
            <div class="hr-label">Comments</div>
            <textarea class="hr-textarea" @bind="newReview.Comments"></textarea>
        </div>
        <div style="margin-top:0.75rem;">
            <button class="hr-btn-primary" @onclick="SaveReviewAsync">Save Review</button>
        </div>
        @if (!string.IsNullOrEmpty(performanceErrorMessage))
        {
            <div style="margin-top:0.5rem;font-size:0.8rem;color:#b91c1c;">@performanceErrorMessage</div>
        }
    </div>

    <div class="hr-card">
        <div class="hr-table-toolbar">
            <div style="font-weight:600;">Recent Reviews (@reviewTotalRecords)</div>
            <div style="display:flex;align-items:center;gap:0.5rem;">
                <span style="font-size:0.8rem;color:#6b7280;">Rows per page:</span>
                <select class="hr-input hr-page-size-select" @bind="reviewPageSize" @bind:after="OnReviewPageSizeChanged">
                    <option value="5">5</option>
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
            </div>
        </div>
        @if (reviews.Any())
        {
            <table class="hr-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Score</th>
                        <th>Reviewer</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in reviews)
                    {
                        <tr>
                            <td>@(r.Employee != null ? r.Employee.FirstName + " " + r.Employee.LastName : "Unknown")</td>
                            <td>@r.Score</td>
                            <td>@r.ReviewerName</td>
                            <td>@r.ReviewDate.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (reviewTotalPages > 1)
            {
                <div class="hr-pagination">
                    <button class="hr-pagination-button" @onclick="() => ChangeReviewPage(reviewCurrentPage - 1)" disabled="@(reviewCurrentPage == 1)">
                        Previous
                    </button>

                    <span class="hr-pagination-info">
                        Page @reviewCurrentPage of @reviewTotalPages
                    </span>

                    @for (int i = Math.Max(1, reviewCurrentPage - 2); i <= Math.Min(reviewTotalPages, reviewCurrentPage + 2); i++)
                    {
                        var pageNum = i;
                        <button class="hr-pagination-button @(reviewCurrentPage == pageNum ? "active" : "")" @onclick="() => ChangeReviewPage(pageNum)">
                            @pageNum
                        </button>
                    }

                    <button class="hr-pagination-button" @onclick="() => ChangeReviewPage(reviewCurrentPage + 1)" disabled="@(reviewCurrentPage == reviewTotalPages)">
                        Next
                    </button>
                </div>
            }
        }
        else
        {
            <div style="font-size:0.85rem;color:#6b7280;">No performance reviews yet.</div>
        }
    </div>
</div>
</HrLayout>

@code {
    private List<Employee> employees = new();
    private List<PerformanceReview> allReviews = new();
    private List<PerformanceReview> reviews = new();
    private PerformanceReview newReview = new PerformanceReview
    {
        ReviewDate = DateTime.Today,
        PeriodStart = DateTime.Today.AddMonths(-3),
        PeriodEnd = DateTime.Today
    };
    private string? performanceErrorMessage;

    private int reviewCurrentPage = 1;
    private int reviewPageSize = 10;
    private int reviewTotalRecords = 0;
    private int reviewTotalPages => (int)Math.Ceiling((double)reviewTotalRecords / reviewPageSize);

    protected override async Task OnInitializedAsync()
    {
        employees = await HrService.GetEmployeesAsync();
        await LoadReviewsAsync();
    }

    private async Task LoadReviewsAsync()
    {
        allReviews = await HrService.GetPerformanceReviewsAsync();
        reviewTotalRecords = allReviews.Count;
        reviewCurrentPage = 1;
        ApplyReviewPagination();
    }

    private async Task SaveReviewAsync()
    {
        performanceErrorMessage = null;

        if (newReview.EmployeeId == 0)
        {
            performanceErrorMessage = "Please select an employee.";
            return;
        }

        if (newReview.Score < 1 || newReview.Score > 5)
        {
            performanceErrorMessage = "Score must be between 1 and 5.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newReview.ReviewerName))
        {
            performanceErrorMessage = "Reviewer name is required.";
            return;
        }

        if (newReview.PeriodStart.HasValue && newReview.PeriodEnd.HasValue && newReview.PeriodEnd < newReview.PeriodStart)
        {
            performanceErrorMessage = "Period end cannot be earlier than period start.";
            return;
        }

        await HrService.SavePerformanceReviewAsync(newReview);

        newReview = new PerformanceReview
        {
            ReviewDate = DateTime.Today,
            PeriodStart = DateTime.Today.AddMonths(-3),
            PeriodEnd = DateTime.Today
        };

        await LoadReviewsAsync();
    }

    private void ApplyReviewPagination()
    {
        reviews = allReviews
            .Skip((reviewCurrentPage - 1) * reviewPageSize)
            .Take(reviewPageSize)
            .ToList();
    }

    private void OnReviewPageSizeChanged()
    {
        reviewCurrentPage = 1;
        ApplyReviewPagination();
    }

    private void ChangeReviewPage(int page)
    {
        if (page < 1 || page > reviewTotalPages)
        {
            return;
        }

        reviewCurrentPage = page;
        ApplyReviewPagination();
    }
}
