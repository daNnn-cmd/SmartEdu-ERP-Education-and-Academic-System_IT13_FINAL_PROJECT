@page "/hr/attendance"
@using System.Linq
@using System.Globalization
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using SmartEduERP.Components.Pages.Hr
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,HR")]
@inject HrService HrService

<PageTitle>HR - Attendance</PageTitle>

<style>
    .hr-page { padding: 1.5rem; }
    .hr-title { font-size: 1.6rem; font-weight: 600; margin-bottom: 0.25rem; }
    .hr-subtitle { font-size: 0.95rem; color: #6b7280; margin-bottom: 1.25rem; }
    .hr-card { background: #fff; border-radius: 12px; border: 1px solid #e5e5e5; padding: 1.25rem; margin-bottom: 1.25rem; }
    .hr-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem 1rem; }
    .hr-label { font-size: 0.8rem; font-weight: 500; color: #4b5563; margin-bottom: 0.2rem; }
    .hr-input, .hr-select { width: 100%; border-radius: 6px; border: 1px solid #d1d5db; padding: 0.45rem 0.6rem; font-size: 0.85rem; }
    .hr-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .hr-table th { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #e5e5e5; font-weight: 500; color: #6b7280; background: #f9fafb; }
    .hr-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #f3f4f6; }
    .hr-btn-primary { border-radius: 8px; border: none; padding: 0.45rem 0.9rem; background: #2563eb; color: #fff; font-size: 0.85rem; cursor: pointer; }
    .hr-badge { font-size: 0.75rem; padding: 0.15rem 0.55rem; border-radius: 999px; font-weight: 500; }
    .hr-badge-present { background: #ecfdf3; color: #166534; }
    .hr-badge-late { background: #fef3c7; color: #92400e; }
    .hr-badge-absent { background: #fee2e2; color: #b91c1c; }
    .hr-table-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; gap: 0.5rem; }
    .hr-pagination { display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-top: 1rem; }
    .hr-pagination-button { border-radius: 6px; border: 1px solid #d1d5db; padding: 0.35rem 0.7rem; background: #fff; font-size: 0.8rem; cursor: pointer; }
    .hr-pagination-button.active { background: #111827; color: #fff; border-color: #111827; }
    .hr-pagination-button:disabled { opacity: 0.5; cursor: not-allowed; }
    .hr-pagination-info { font-size: 0.8rem; color: #6b7280; margin: 0 0.75rem; }
    .hr-page-size-select { width: auto; min-width: 120px; }
</style>

<HrLayout>
<div class="hr-page">
    <div class="hr-title">Employee Attendance</div>
    <div class="hr-subtitle">Record daily time-in/time-out and automatically track lateness and absences.</div>

    <div class="hr-card">
        <div class="hr-grid">
            <div>
                <div class="hr-label">Date</div>
                <InputText class="hr-input" @bind-Value="dateText" placeholder="2025-01-31" />
            </div>
            <div>
                <div class="hr-label">Employee</div>
                <select class="hr-select" @bind="editingAttendance.EmployeeId">
                    <option value="0">Select employee...</option>
                    @foreach (var e in employees)
                    {
                        <option value="@e.EmployeeId">@e.FirstName @e.LastName</option>
                    }
                </select>
            </div>
            <div>
                <div class="hr-label">Time In</div>
                <InputText class="hr-input" @bind-Value="timeInText" placeholder="09:00" />
            </div>
            <div>
                <div class="hr-label">Time Out</div>
                <InputText class="hr-input" @bind-Value="timeOutText" placeholder="17:00" />
            </div>
        </div>
        <div style="margin-top:0.75rem;">
            <button class="hr-btn-primary" @onclick="SaveAttendanceAsync">Save Attendance</button>
        </div>
        @if (!string.IsNullOrEmpty(attendanceErrorMessage))
        {
            <div style="margin-top:0.5rem;font-size:0.8rem;color:#b91c1c;">@attendanceErrorMessage</div>
        }
    </div>

    <div class="hr-card">
        <div class="hr-table-toolbar">
            <div style="font-weight:600;">Attendance Records (@attendanceTotalRecords) - @selectedDate.ToString("MMM dd, yyyy")</div>
            <div style="display:flex;align-items:center;gap:0.5rem;">
                <span style="font-size:0.8rem;color:#6b7280;">Rows per page:</span>
                <select class="hr-input hr-page-size-select" @bind="attendancePageSize" @bind:after="OnAttendancePageSizeChanged">
                    <option value="5">5</option>
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                </select>
            </div>
        </div>
        @if (attendanceRecords.Any())
        {
            <table class="hr-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Time In</th>
                        <th>Time Out</th>
                        <th>Status</th>
                        <th>Late (min)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in attendanceRecords)
                    {
                        <tr>
                            <td>@(r.Employee != null ? r.Employee.FirstName + " " + r.Employee.LastName : "Unknown")</td>
                            <td>@(r.TimeIn.HasValue ? r.TimeIn.Value.ToString(@"hh\:mm") : "-")</td>
                            <td>@(r.TimeOut.HasValue ? r.TimeOut.Value.ToString(@"hh\:mm") : "-")</td>
                            <td>
                                <span class="hr-badge @(r.Status == "Present" ? "hr-badge-present" : r.Status == "Late" ? "hr-badge-late" : "hr-badge-absent")">@r.Status</span>
                            </td>
                            <td>@r.MinutesLate</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (attendanceTotalPages > 1)
            {
                <div class="hr-pagination">
                    <button class="hr-pagination-button" @onclick="() => ChangeAttendancePage(attendanceCurrentPage - 1)" disabled="@(attendanceCurrentPage == 1)">
                        Previous
                    </button>

                    <span class="hr-pagination-info">
                        Page @attendanceCurrentPage of @attendanceTotalPages
                    </span>

                    @for (int i = Math.Max(1, attendanceCurrentPage - 2); i <= Math.Min(attendanceTotalPages, attendanceCurrentPage + 2); i++)
                    {
                        var pageNum = i;
                        <button class="hr-pagination-button @(attendanceCurrentPage == pageNum ? "active" : "")" @onclick="() => ChangeAttendancePage(pageNum)">
                            @pageNum
                        </button>
                    }

                    <button class="hr-pagination-button" @onclick="() => ChangeAttendancePage(attendanceCurrentPage + 1)" disabled="@(attendanceCurrentPage == attendanceTotalPages)">
                        Next
                    </button>
                </div>
            }
        }
        else
        {
            <div style="font-size:0.85rem;color:#6b7280;">No attendance records for this date.</div>
        }
    </div>
</div>
</HrLayout>

@code {
    private DateTime selectedDate = DateTime.Today;
    private List<Employee> employees = new();
    private List<EmployeeAttendance> allAttendanceRecords = new();
    private List<EmployeeAttendance> attendanceRecords = new();

    private EmployeeAttendance editingAttendance = new();
    private string? dateText;
    private string? timeInText;
    private string? timeOutText;
    private string? attendanceErrorMessage;

    private int attendanceCurrentPage = 1;
    private int attendancePageSize = 10;
    private int attendanceTotalRecords = 0;
    private int attendanceTotalPages => (int)Math.Ceiling((double)attendanceTotalRecords / attendancePageSize);

    protected override async Task OnInitializedAsync()
    {
        employees = await HrService.GetEmployeesAsync();
        dateText = selectedDate.ToString("yyyy-MM-dd");
        await LoadAttendanceAsync();
    }

    private async Task LoadAttendanceAsync()
    {
        allAttendanceRecords = await HrService.GetAttendanceAsync(selectedDate);
        attendanceTotalRecords = allAttendanceRecords.Count;
        attendanceCurrentPage = 1;
        ApplyAttendancePagination();
    }

    private async Task SaveAttendanceAsync()
    {
        attendanceErrorMessage = null;

        if (string.IsNullOrWhiteSpace(dateText))
        {
            attendanceErrorMessage = "Please enter a date in format YYYY-MM-DD (e.g., 2025-01-31).";
            return;
        }

        if (!DateTime.TryParseExact(dateText, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsedDate))
        {
            attendanceErrorMessage = "Invalid Date. Please use YYYY-MM-DD (e.g., 2025-01-31).";
            return;
        }

        selectedDate = parsedDate.Date;

        if (editingAttendance.EmployeeId == 0)
        {
            attendanceErrorMessage = "Please select an employee.";
            return;
        }

        var hasTimeIn = !string.IsNullOrWhiteSpace(timeInText);
        var hasTimeOut = !string.IsNullOrWhiteSpace(timeOutText);

        TimeSpan? parsedTimeIn = null;
        TimeSpan? parsedTimeOut = null;

        if (hasTimeIn)
        {
            if (!TimeSpan.TryParseExact(timeInText, "hh\\:mm", CultureInfo.InvariantCulture, out var ti))
            {
                attendanceErrorMessage = "Invalid Time In. Please use HH:mm (e.g., 09:00).";
                return;
            }
            parsedTimeIn = ti;
        }

        if (hasTimeOut)
        {
            if (!TimeSpan.TryParseExact(timeOutText, "hh\\:mm", CultureInfo.InvariantCulture, out var to))
            {
                attendanceErrorMessage = "Invalid Time Out. Please use HH:mm (e.g., 17:00).";
                return;
            }
            parsedTimeOut = to;
        }

        if (parsedTimeIn.HasValue && parsedTimeOut.HasValue && parsedTimeOut < parsedTimeIn)
        {
            attendanceErrorMessage = "Time Out cannot be earlier than Time In.";
            return;
        }

        editingAttendance.Date = selectedDate.Date;
        editingAttendance.TimeIn = parsedTimeIn;
        editingAttendance.TimeOut = parsedTimeOut;

        await HrService.SaveAttendanceAsync(editingAttendance);

        // reset for next entry
        editingAttendance = new EmployeeAttendance { EmployeeId = 0, Date = selectedDate.Date };
        timeInText = null;
        timeOutText = null;
        dateText = selectedDate.ToString("yyyy-MM-dd");

        await LoadAttendanceAsync();
    }

    private void ApplyAttendancePagination()
    {
        attendanceRecords = allAttendanceRecords
            .Skip((attendanceCurrentPage - 1) * attendancePageSize)
            .Take(attendancePageSize)
            .ToList();
    }

    private void OnAttendancePageSizeChanged()
    {
        attendanceCurrentPage = 1;
        ApplyAttendancePagination();
    }

    private void ChangeAttendancePage(int page)
    {
        if (page < 1 || page > attendanceTotalPages)
        {
            return;
        }

        attendanceCurrentPage = page;
        ApplyAttendancePagination();
    }
}
