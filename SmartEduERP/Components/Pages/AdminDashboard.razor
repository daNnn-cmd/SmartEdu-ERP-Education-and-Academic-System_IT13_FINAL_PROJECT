    // Helper: compute a sortable numeric key for labels like "MMM yyyy", "Qn yyyy", or "yyyy"
    private int GetLabelSortKey(string label, string timeRange)
    {
        var tr = (timeRange ?? "month").ToLower();
        if (tr == "year")
        {
            return int.TryParse(label, out var y) ? y : int.MaxValue;
        }
        if (tr == "quarter")
        {
            try
            {
                // Expect format: Q1 2024
                var parts = label.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                if (parts.Length == 2 && parts[0].StartsWith("Q", StringComparison.OrdinalIgnoreCase))
                {
                    var qStr = parts[0].Substring(1);
                    var quarter = int.Parse(qStr);
                    var year = int.Parse(parts[1]);
                    return year * 10 + quarter; // ensures chronological order within year
                }
            }
            catch { }
            return int.MaxValue;
        }
        // Default monthly: MMM yyyy
        try
        {
            if (System.DateTime.TryParseExact(label, "MMM yyyy", System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var dt))
            {
                return dt.Year * 100 + dt.Month; // chronological key
            }
        }
        catch { }
        return int.MaxValue;
    }

