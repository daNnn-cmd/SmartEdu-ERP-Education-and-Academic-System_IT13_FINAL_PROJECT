        StateHasChanged();
    }

    private void HideLogoutConfirmation()
    {
        showLogoutConfirmation = false;
        isLoggingOut = false;
        StateHasChanged();
    }

    private async Task ConfirmLogout()
    {
        isLoggingOut = true;
        StateHasChanged();

        try
        {
            // Try to use proper logout if available
            if (AuthStateProvider is AuthStateProvider authProvider && authProvider.GetType().GetMethod("LogoutAsync") != null)
            {
                await ((dynamic)AuthStateProvider).LogoutAsync();
            }
            else
            {
                AuthStateProvider.MarkUserAsLoggedOut();
            }

            Navigation.NavigateTo("/", true);
        }
        catch
        {
            // Fallback to simple logout
            AuthStateProvider.MarkUserAsLoggedOut();
            Navigation.NavigateTo("/", true);
        }
    }

    private void NavigateToStudents()
    {
        Navigation.NavigateTo("/students");
    }

    private void NavigateToTeachers()
    {
        Navigation.NavigateTo("/teachers");
    }

    private void NavigateToPayments()
    {
        Navigation.NavigateTo("/payments");
    }

