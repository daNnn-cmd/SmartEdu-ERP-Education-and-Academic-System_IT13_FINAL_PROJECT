        if (selectedMonth > 0)
        {
            var monthName = availableMonths.First(m => m.Value == selectedMonth).Key;
            return $"{monthName} {selectedYear}";
        }

        return selectedTimeRange switch
        {
            "year" => $"{selectedYear}",
            "quarter" => $"{selectedYear} Quarters",
            _ => $"{selectedYear} Monthly"
        };
    }

