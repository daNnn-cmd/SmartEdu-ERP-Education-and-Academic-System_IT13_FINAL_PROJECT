@page "/teachers"
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using SmartEduERP.Components.Shared
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject TeacherService TeacherService
@inject ExportService ExportService
@inject NavigationManager Navigation
@inject AuthStateProvider AuthStateProvider
@inject AuditLogService AuditLogService
@inject IJSRuntime JS
@inject IToastService ToastService
@inject IGlobalSyncService GlobalSyncService
@inject IBidirectionalSyncService BidirectionalSyncService

<PageTitle>Teachers - SmartEduERP</PageTitle>

<style>
    .dashboard-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f5f5f5;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .sidebar {
        width: 260px;
        background: white;
        border-right: 1px solid #e5e5e5;
        position: fixed;
        height: 100vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #e5e5e5;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .sidebar-logo {
        width: 48px;
        height: 48px;
    }

    .sidebar-title {
        font-size: 1rem;
        font-weight: 600;
        margin: 0;
        color: #000;
    }

    .sidebar-subtitle {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .sidebar-content {
        flex: 1;
        padding: 1rem 0;
    }

    .sidebar-section-label {
        padding: 0.5rem 1rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: #737373;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-menu-item {
        padding: 0 0.75rem;
    }

    .sidebar-menu-button {
        width: 100%;
        padding: 0.625rem 0.75rem;
        background: none;
        border: none;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.2s;
        text-decoration: none;
    }

        .sidebar-menu-button:hover {
            background: #f5f5f5;
            color: #000;
        }

        .sidebar-menu-button.active {
            background: #f0f0f0;
            color: #000;
            font-weight: 500;
        }

    .sidebar-menu-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .sidebar-footer {
        padding: 1rem;
        border-top: 1px solid #e5e5e5;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        background: #f0f0f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
    }

    .user-details {
        flex: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 0.875rem;
        font-weight: 500;
        color: #000;
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .user-role {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .logout-button {
        width: 100%;
        padding: 0.625rem;
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

        .logout-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

    .main-content {
        margin-left: 260px;
        flex: 1;
        padding: 1.5rem;
    }

    .page-header {
        margin-bottom: 1.5rem;
    }

        .page-header h1 {
            font-size: 1.75rem;
            font-weight: 600;
            color: #000;
            margin: 0 0 0.25rem 0;
        }

        .page-header p {
            font-size: 0.9375rem;
            color: #737373;
            margin: 0;
        }

    .header-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .export-button, .add-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
    }

    .export-button {
        background: white;
        color: #404040;
    }

        .export-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .export-button:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    .add-button {
        background: #000;
        color: white;
        border-color: #000;
    }

        .add-button:hover {
            background: #404040;
            border-color: #404040;
        }

    .content-card {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        overflow: hidden;
    }

    .content-card-header {
        padding: 1.25rem;
        border-bottom: 1px solid #e5e5e5;
    }

    .content-card-body {
        padding: 1.25rem;
    }

    .filters-grid {
        display: grid;
        grid-template-columns: 1fr auto auto auto auto;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .search-input, .filter-select, .page-size-select {
        padding: 0.625rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        background: white;
    }

        .search-input:focus, .filter-select:focus, .page-size-select:focus {
            outline: none;
            border-color: #000;
        }

    .filter-button {
        padding: 0.625rem 1rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        background: white;
        color: #404040;
        cursor: pointer;
        transition: all 0.2s;
    }

        .filter-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .filter-button.primary {
            background: #000;
            color: white;
            border-color: #000;
        }

            .filter-button.primary:hover {
                background: #404040;
                border-color: #404040;
            }

    .results-count {
        font-size: 0.75rem;
        color: #737373;
        margin-bottom: 1rem;
    }

    .teachers-table {
        width: 100%;
        border-collapse: collapse;
    }

        .teachers-table th {
            text-align: left;
            padding: 0.75rem;
            font-size: 0.75rem;
            font-weight: 500;
            color: #737373;
            border-bottom: 1px solid #e5e5e5;
            cursor: pointer;
            user-select: none;
        }

            .teachers-table th:hover {
                background: #f5f5f5;
            }

        .teachers-table td {
            padding: 0.75rem;
            font-size: 0.875rem;
            border-bottom: 1px solid #f5f5f5;
        }

        .teachers-table tr:last-child td {
            border-bottom: none;
        }

        .teachers-table tr:hover {
            background: #fafafa;
        }

    .department-badge {
        padding: 0.25rem 0.625rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 500;
        white-space: nowrap;
    }

        .department-badge.computer-science {
            background: #dbeafe;
            color: #1e40af;
        }

        .department-badge.mathematics {
            background: #fef3c7;
            color: #92400e;
        }

        .department-badge.english {
            background: #dcfce7;
            color: #166534;
        }

        .department-badge.science {
            background: #f3e8ff;
            color: #7e22ce;
        }

        .department-badge.other {
            background: #f5f5f5;
            color: #737373;
        }

    .position-text {
        font-weight: 500;
        color: #000;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
    }

    .action-button {
        padding: 0.375rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 4px;
        font-size: 0.75rem;
        background: white;
        color: #404040;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
    }

        .action-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .action-button.edit {
            border-color: #3b82f6;
            color: #3b82f6;
        }

            .action-button.edit:hover {
                background: #3b82f6;
                color: white;
            }

        .action-button.archive {
            border-color: #f59e0b;
            color: #f59e0b;
        }

            .action-button.archive:hover {
                background: #f59e0b;
                color: white;
            }

    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1.5rem;
    }

    .pagination-button {
        padding: 0.5rem 0.75rem;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        background: white;
        color: #404040;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .pagination-button:hover:not(:disabled) {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

        .pagination-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .pagination-button.active {
            background: #000;
            color: white;
            border-color: #000;
        }

    .pagination-info {
        font-size: 0.75rem;
        color: #737373;
        margin: 0 1rem;
    }

    .loading-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 400px;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #f5f5f5;
        border-top-color: #000;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: #737373;
    }

    .empty-state-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    /* Logout Confirmation Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        max-width: 400px;
        width: 90%;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }

    .modal-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .modal-icon {
        width: 40px;
        height: 40px;
        background: #fef3c7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #f59e0b;
    }

    .modal-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #000;
        margin: 0;
        font-family: Arial, sans-serif;
    }

    .modal-body {
        margin-bottom: 1.5rem;
    }

    .modal-text {
        font-size: 0.875rem;
        color: #737373;
        line-height: 1.5;
        margin: 0;
        font-family: Arial, sans-serif;
    }

    .modal-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }

    .modal-button {
        padding: 0.625rem 1.25rem;
        border-radius: 6px;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
    }

    .modal-button-cancel {
        background: white;
        color: #404040;
        border: 1px solid #e5e5e5;
    }

        .modal-button-cancel:hover {
            background: #f5f5f5;
        }

    .modal-button-confirm {
        background: #000;
        color: white;
    }

        .modal-button-confirm:hover {
            background: #262626;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .date-text {
        font-size: 0.75rem;
        color: #737373;
        white-space: nowrap;
    }

    /* Sync Status Styles */
    .sync-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        padding: 0.5rem;
        border-radius: 4px;
        font-size: 0.75rem;
    }

        .sync-status.syncing {
            background: #f0f9ff;
            color: #0369a1;
            border: 1px solid #bae6fd;
        }

        .sync-status.success {
            background: #f0fdf4;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .sync-status.error {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

    .sync-spinner {
        width: 12px;
        height: 12px;
        border: 2px solid transparent;
        border-top-color: currentColor;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    .sync-badge {
    background: #dc2626;
    color: white;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    font-size: 0.7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -5px;
    left: 0px;   /* 👈 moved to left */
    right: auto;  /* 👈 disable right positioning */
}

    .sidebar-menu-item {
        position: relative;
    }
</style>

<div class="dashboard-wrapper">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo.png" alt="Logo" class="sidebar-logo" />
            <div>
                <h2 class="sidebar-title">Smart EDU</h2>
                <p class="sidebar-subtitle">Academic System</p>
            </div>
        </div>

        <div class="sidebar-content">
            <div class="sidebar-section-label">Main Menu</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item">
                    <a href="/admin-dashboard" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/students" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                        <span>Student Management</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/teachers" class="sidebar-menu-button active">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                            <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
                        </svg>
                        <span>Teacher Management</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/subjects" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
                        </svg>
                        <span>Academic Management</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/admin/enrollment-approvals" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
                        </svg>
                        <span>Enrollment Approvals</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/payments" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="1" x2="12" y2="23"></line>
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                        </svg>
                        <span>Student Tuition Payments</span>
                    </a>
                </li>
               
               
                
                <li class="sidebar-menu-item">
                    <a href="/admin/users" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M22 11l-3-3m0 0l-3 3m3-3v7"></path>
                        </svg>
                        <span>Manage Users</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <NavLink href="/audit-logs" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <span>Audit Logs</span>
                    </NavLink>
                </li>
                

                <!-- Sync to Cloud Button -->
                <li class="sidebar-menu-item">
                    <button class="sidebar-menu-button" @onclick="GlobalSync" disabled="@isSyncing">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"></path>
                            <line x1="16" y1="5" x2="22" y2="5"></line>
                            <line x1="19" y1="2" x2="19" y2="8"></line>
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"></path>
                        </svg>
                        <span>Sync All to Cloud</span>
                        @if (isSyncing)
                        {
                            <div class="sync-spinner"></div>
                        }
                        @if (pendingSyncCount > 0 && !isSyncing)
                        {
                            <span class="sync-badge">@pendingSyncCount</span>
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(syncMessage))
                    {
                        <div class="sync-status @syncStatusClass">
                            @syncMessage
                        </div>
                    }
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="user-details">
                    <p class="user-name">@userName</p>
                    <p class="user-role">admin</p>
                </div>
            </div>
            <button class="logout-button" @onclick="ShowLogoutConfirmation">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                <span>Log Out</span>
            </button>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="page-header">
            <h1>Teacher Management</h1>
            <p>Manage teacher records, departments, and academic positions</p>
            <div class="header-actions">
                <button class="export-button" @onclick="ExportToExcel" disabled="@exporting">
                    @if (exporting)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spinner">
                            <path d="M21 12a9 9 0 11-6.219-8.56"></path>
                        </svg>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                    }
                    <span>Export Excel</span>
                </button>
                <button class="export-button" @onclick="ExportToPDF" disabled="@exporting">
                    @if (exporting)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spinner">
                            <path d="M21 12a9 9 0 11-6.219-8.56"></path>
                        </svg>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                            <line x1="16" y1="13" x2="8" y2="13"></line>
                            <line x1="16" y1="17" x2="8" y2="17"></line>
                            <polyline points="10 9 9 9 8 9"></polyline>
                        </svg>
                    }
                    <span>Export PDF</span>
                </button>
                <a href="/teachers/create" class="add-button">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    <span>Add New Teacher</span>
                </a>
            </div>
        </div>

        @if (loading)
        {
            <div class="loading-container">
                <div class="spinner"></div>
            </div>
        }
        else
        {
            <div class="content-card">
                <div class="content-card-header">
                    <div class="filters-grid">
                        <input type="text"
                               class="search-input"
                               placeholder="Search by name or email..."
                               @bind="searchTerm"
                               @bind:event="oninput"
                               @onkeyup="HandleSearch" />

                        <select class="filter-select" @bind="departmentFilter" @bind:after="ApplyFilters">
                            <option value="">All Departments</option>
                            <option value="Computer Science">Computer Science</option>
                            <option value="Mathematics">Mathematics</option>
                            <option value="English">English</option>
                            <option value="Science">Science</option>
                        </select>

                        <button class="filter-button primary" @onclick="ApplyFilters">
                            Search
                        </button>

                        <button class="filter-button" @onclick="ClearFilters">
                            Clear
                        </button>

                        <select class="page-size-select" @bind="pageSize" @bind:after="LoadTeachers">
                            <option value="10">10 per page</option>
                            <option value="25">25 per page</option>
                            <option value="50">50 per page</option>
                            <option value="100">100 per page</option>
                        </select>
                    </div>

                    <div class="results-count">
                        Showing @filteredTeachers.Count of @totalRecords teachers
                    </div>
                </div>

                <div class="content-card-body">
                    @if (filteredTeachers.Any())
                    {
                        <div class="table-responsive">
                            <table class="teachers-table">
                                <thead>
                                    <tr>
                                        
                                        <th @onclick='() => SortBy("FirstName")'>
                                            Name @GetSortIcon("FirstName")
                                        </th>
                                        <th @onclick='() => SortBy("Email")'>
                                            Email @GetSortIcon("Email")
                                        </th>
                                        <th @onclick='() => SortBy("Department")'>
                                            Department @GetSortIcon("Department")
                                        </th>
                                        <th @onclick='() => SortBy("Position")'>
                                            Position @GetSortIcon("Position")
                                        </th>
                                        <!-- ADDED: Registration Date column -->
                                        <th @onclick='() => SortBy("RegistrationDate")'>
                                            Registration Date @GetSortIcon("RegistrationDate")
                                        </th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var teacher in filteredTeachers)
                                    {
                                        <tr>
                                          
                                            <td>
                                                <strong>@teacher.FirstName @teacher.LastName</strong>
                                            </td>
                                            <td>@teacher.Email</td>
                                            <td>@teacher.Department</td>
                                            <td>
                                                <span class="position-text">@teacher.Position</span>
                                            </td>
                                            <!-- ADDED: Registration Date cell -->
                                            <td>
                                                <span class="date-text">@teacher.RegistrationDate.ToString("MMM dd, yyyy")</span>
                                            </td>
                                            <td>
                                                <div class="action-buttons">
                                                    <a href="/teachers/edit/@teacher.TeacherId" class="action-button edit">
                                                        Edit
                                                    </a>
                                                    <button class="action-button archive"
                                                            @onclick='() => ShowArchiveConfirmation(teacher.TeacherId, $"{teacher.FirstName} {teacher.LastName}")'>
                                                        Archive
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>


                            </table>
                        </div>

                        <!-- Pagination -->
                        @if (totalPages > 1)
                        {
                            <div class="pagination">
                                <button class="pagination-button"
                                        @onclick="() => ChangePage(currentPage - 1)"
                                        disabled="@(currentPage == 1)">
                                    Previous
                                </button>

                                <span class="pagination-info">
                                    Page @currentPage of @totalPages
                                </span>

                                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                                {
                                    var pageNum = i;
                                    <button class="pagination-button @(currentPage == pageNum ? "active" : "")"
                                            @onclick="() => ChangePage(pageNum)">
                                        @pageNum
                                    </button>
                                }

                                <button class="pagination-button"
                                        @onclick="() => ChangePage(currentPage + 1)"
                                        disabled="@(currentPage == totalPages)">
                                    Next
                                </button>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">👨‍🏫</div>
                            <h3>No Teachers Found</h3>
                            <p>
                                @if (string.IsNullOrEmpty(searchTerm) && string.IsNullOrEmpty(departmentFilter))
                                {
                                    <text>No teachers have been added yet. Click "Add New Teacher" to get started.</text>
                                }
                                else
                                {
                                    <text>No teachers match your search criteria. Try adjusting your filters.</text>
                                }
                            </p>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Confirmation Dialogs -->
    <ConfirmationDialog IsVisible="showLogoutConfirmation" Title="Confirm Logout"
                        Message="Are you sure you want to log out? You will need to sign in again to access your account."
                        ConfirmText="Log Out" ProcessingText="Logging out..." Type="@ConfirmationDialog.ConfirmationType.Logout"
                        IsProcessing="isLoggingOut" OnConfirm="ConfirmLogout" OnCancel="HideLogoutConfirmation" />

    <!-- Archive Confirmation Dialog -->
    <ConfirmationDialog IsVisible="showArchiveConfirmation"
                        Title="Archive Teacher"
                        Message="@archiveConfirmationMessage"
                        ConfirmText="Archive"
                        ProcessingText="Archiving..."
                        Type="ConfirmationDialog.ConfirmationType.Warning"
                        IsProcessing="isArchiving"
                        ShowTextInput="true"
                        InputLabel="Reason for archiving"
                        InputPlaceholder="Type the reason for archiving this teacher..."
                        IsInputRequired="true"
                        InputMaxLength="500"
                        @bind-InputText="archiveReason"
                        OnConfirm="ConfirmArchive"
                        OnCancel="CancelArchive" />
</div>

@code {
    private List<Teacher> teachers = new();
    private List<Teacher> filteredTeachers = new();
    private string searchTerm = "";
    private string departmentFilter = "";
    private string sortColumn = "TeacherId";
    private bool sortAscending = false;
    private int currentPage = 1;
    private int pageSize = 25;
    private int totalRecords = 0;
    private int totalPages => (int)Math.Ceiling((double)totalRecords / pageSize);
    private bool loading = true;
    private bool exporting = false;
    private bool showLogoutConfirmation = false;
    private bool isLoggingOut = false;
    private string userName = "";

    // Archive confirmation
    private bool showArchiveConfirmation = false;
    private bool isArchiving = false;
    private int teacherToArchiveId = 0;
    private string archiveConfirmationMessage = "";
    private string archiveReason = "";

    // Sync properties
    private bool isSyncing = false;
    private string syncMessage = "";
    private string syncStatusClass = "";
    private int pendingSyncCount = 0;
    private System.Threading.Timer? syncStatusTimer;

    protected override async Task OnInitializedAsync()
    {
        userName = AuthStateProvider.GetCurrentUsername() ?? "Admin";
        await Task.WhenAll(
            LoadTeachers(),
            LoadPendingSyncCount()
        );
        
        // Load pending sync count and start periodic updates
        syncStatusTimer = new System.Threading.Timer(async _ =>
        {
            await LoadPendingSyncCount();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromMinutes(1));
    }

    private async Task LoadTeachers()
    {
        loading = true;
        teachers = await TeacherService.GetAllTeachersAsync();
        ApplyFiltersAndSort();
        loading = false;
    }

    private void ApplyFiltersAndSort()
    {
        var query = teachers.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var lower = searchTerm.ToLower();
            query = query.Where(t =>
                (t.FirstName?.ToLower().Contains(lower) ?? false) ||
                (t.LastName?.ToLower().Contains(lower) ?? false) ||
                (t.Email?.ToLower().Contains(lower) ?? false));
        }

        if (!string.IsNullOrEmpty(departmentFilter))
        {
            query = query.Where(t => t.Department == departmentFilter);
        }

        totalRecords = query.Count();

        query = sortColumn switch
        {
            "FirstName" => sortAscending ? query.OrderBy(t => t.FirstName) : query.OrderByDescending(t => t.FirstName),
            "Email" => sortAscending ? query.OrderBy(t => t.Email) : query.OrderByDescending(t => t.Email),
            "Department" => sortAscending ? query.OrderBy(t => t.Department) : query.OrderByDescending(t => t.Department),
            "Position" => sortAscending ? query.OrderBy(t => t.Position) : query.OrderByDescending(t => t.Position),
            "RegistrationDate" => sortAscending ? query.OrderBy(t => t.RegistrationDate) : query.OrderByDescending(t => t.RegistrationDate),
            _ => sortAscending ? query.OrderBy(t => t.TeacherId) : query.OrderByDescending(t => t.TeacherId)
        };

        filteredTeachers = query.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
    }

    private async Task HandleSearch()
    {
        currentPage = 1;
        ApplyFiltersAndSort();
        await Task.CompletedTask;
    }

    private async Task ApplyFilters()
    {
        currentPage = 1;
        ApplyFiltersAndSort();
        await Task.CompletedTask;
    }

    private async Task ClearFilters()
    {
        searchTerm = "";
        departmentFilter = "";
        sortColumn = "TeacherId";
        sortAscending = false;
        currentPage = 1;
        ApplyFiltersAndSort();
        await Task.CompletedTask;
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        ApplyFiltersAndSort();
    }

    private string GetSortIcon(string column)
    {
        if (sortColumn != column) return "";
        return sortAscending ? " ▲" : " ▼";
    }

    private void ChangePage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        ApplyFiltersAndSort();
    }

    private void ShowArchiveConfirmation(int teacherId, string teacherName)
    {
        teacherToArchiveId = teacherId;
        archiveConfirmationMessage = $"Are you sure you want to archive the teacher '{teacherName}'? This action will move the teacher to archived records.";
        archiveReason = string.Empty;
        showArchiveConfirmation = true;
    }

    private async Task ConfirmArchive()
    {
        isArchiving = true;
        StateHasChanged();

        try
        {
            // Archive locally with reason (no schema change; reason recorded via audit log and sync queue)
            if (await TeacherService.SoftDeleteTeacherAsync(teacherToArchiveId, archiveReason))
            {
                await LoadTeachers();

                // After local archive, immediately sync teacher changes to cloud with retries
                await RunImmediateTeacherSyncWithRetry("archived");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error archiving teacher: {ex.Message}");
            ToastService.ShowError($"Error archiving teacher: {ex.Message}");
        }
        finally
        {
            isArchiving = false;
            showArchiveConfirmation = false;
            teacherToArchiveId = 0;
            archiveConfirmationMessage = "";
            archiveReason = string.Empty;
        }
    }

    private void CancelArchive()
    {
        showArchiveConfirmation = false;
        teacherToArchiveId = 0;
        archiveConfirmationMessage = "";
        archiveReason = string.Empty;
    }

    private void ArchiveTeacher(int id)
    {
        // This method is kept for backward compatibility but now shows confirmation
        var teacher = teachers.FirstOrDefault(t => t.TeacherId == id);
        if (teacher != null)
        {
            ShowArchiveConfirmation(id, $"{teacher.FirstName} {teacher.LastName}");
        }
    }

    private async Task ExportToExcel()
    {
        exporting = true;
        try
        {
            var allTeachers = await TeacherService.GetAllTeachersAsync();
            var excelBytes = ExportService.ExportTeachersToExcel(allTeachers);
            var fileName = $"Teachers_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            var base64 = Convert.ToBase64String(excelBytes);
            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Export failed: {ex.Message}");
        }
        finally
        {
            exporting = false;
        }
    }

    private async Task ExportToPDF()
    {
        exporting = true;
        try
        {
            var allTeachers = await TeacherService.GetAllTeachersAsync();
            var pdfBytes = ExportService.ExportTeachersToPDF(allTeachers);
            var fileName = $"Teachers_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";
            var base64 = Convert.ToBase64String(pdfBytes);
            await JS.InvokeVoidAsync("downloadFile", fileName, base64, "application/pdf");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Export failed: {ex.Message}");
        }
        finally
        {
            exporting = false;
        }
    }

    private string GetDepartmentClass(string? department)
    {
        return department?.ToLower() switch
        {
            "computer science" => "computer-science",
            "mathematics" => "mathematics",
            "english" => "english",
            "science" => "science",
            _ => "other"
        };
    }

    // Logout functionality
    private void ShowLogoutConfirmation()
    {
        showLogoutConfirmation = true;
        StateHasChanged();
    }

    private void HideLogoutConfirmation()
    {
        showLogoutConfirmation = false;
        isLoggingOut = false;
        StateHasChanged();
    }

    private async Task ConfirmLogout()
    {
        isLoggingOut = true;
        StateHasChanged();

        try
        {
            // Try to use proper logout if available
            if (AuthStateProvider is AuthStateProvider authProvider && authProvider.GetType().GetMethod("LogoutAsync") != null)
            {
                await ((dynamic)AuthStateProvider).LogoutAsync();
            }
            else
            {
                AuthStateProvider.MarkUserAsLoggedOut();
            }

            Navigation.NavigateTo("/", true);
        }
        catch
        {
            // Fallback to simple logout
            AuthStateProvider.MarkUserAsLoggedOut();
            Navigation.NavigateTo("/", true);
        }
    }

    // Sync to Cloud functionality
    private async Task GlobalSync()
    {
        if (isSyncing) return;

        isSyncing = true;
        syncMessage = "🔄 Syncing bidirectionally (Local ↔ Cloud)...";
        syncStatusClass = "syncing";
        StateHasChanged();

        try
        {
            // Use the new bidirectional sync service
            var result = await BidirectionalSyncService.SyncAsync();

            if (result.Success)
            {
                syncMessage = $"✅ Bidirectional sync successful! +{result.RecordsAdded} ~{result.RecordsUpdated} -{result.RecordsDeleted}";
                syncStatusClass = "success";
                ToastService.ShowSuccess($"Sync completed: {result.RecordsAdded} added, {result.RecordsUpdated} updated");
                
                // Refresh pending count
                await LoadPendingSyncCount();
            }
            else
            {
                var errorMsg = result.Errors.Any() ? string.Join(", ", result.Errors) : "Unknown error";
                syncMessage = $"❌ Sync failed: {errorMsg}";
                syncStatusClass = "error";
                ToastService.ShowWarning($"Sync failed: {errorMsg}");
            }
        }
        catch (Exception ex)
        {
            syncMessage = $"❌ Sync error: {ex.Message}";
            syncStatusClass = "error";
            ToastService.ShowError($"Sync error: {ex.Message}");
        }
        finally
        {
            isSyncing = false;
            StateHasChanged();

            // Clear message after 5 seconds
            _ = Task.Run(async () =>
            {
                await Task.Delay(5000);
                syncMessage = "";
                syncStatusClass = "";
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task RunImmediateTeacherSyncWithRetry(string operationDescription)
    {
        const int maxAttempts = 3;
        int attempt = 0;

        while (attempt < maxAttempts)
        {
            attempt++;

            try
            {
                isSyncing = true;
                syncMessage = $"🔄 Syncing {operationDescription} teacher to cloud (attempt {attempt}/{maxAttempts})...";
                syncStatusClass = "syncing";
                StateHasChanged();

                var result = await BidirectionalSyncService.SyncAsync();

                if (result.Success)
                {
                    syncMessage = $"✅ Teacher {operationDescription} and synced! +{result.RecordsAdded} ~{result.RecordsUpdated} -{result.RecordsDeleted}";
                    syncStatusClass = "success";
                    ToastService.ShowSuccess($"Teacher {operationDescription} and synced successfully.");

                    await LoadPendingSyncCount();
                    break;
                }
                else
                {
                    var errorMsg = result.Errors != null && result.Errors.Any() ? string.Join(", ", result.Errors) : "Unknown error";
                    syncMessage = $"❌ Sync failed ({attempt}/{maxAttempts}): {errorMsg}";
                    syncStatusClass = "error";

                    if (attempt >= maxAttempts)
                    {
                        ToastService.ShowWarning($"Teacher {operationDescription} locally, but sync failed after {maxAttempts} attempts: {errorMsg}");
                    }
                    else
                    {
                        await Task.Delay(TimeSpan.FromSeconds(3));
                        continue;
                    }
                }
            }
            catch (Exception ex)
            {
                syncMessage = $"❌ Sync error ({attempt}/{maxAttempts}): {ex.Message}";
                syncStatusClass = "error";

                if (attempt >= maxAttempts)
                {
                    ToastService.ShowError($"Teacher {operationDescription} locally, but sync encountered repeated errors: {ex.Message}");
                }
                else
                {
                    await Task.Delay(TimeSpan.FromSeconds(3));
                    continue;
                }
            }
            finally
            {
                isSyncing = false;
                StateHasChanged();
            }

            // Exit loop once we either succeed or decide not to retry further
            break;
        }

        // Clear sync UI after a short delay so the page stays clean
        _ = Task.Run(async () =>
        {
            await Task.Delay(5000);
            syncMessage = string.Empty;
            syncStatusClass = string.Empty;
            await InvokeAsync(StateHasChanged);
        });
    }

    // Load pending sync count
    private async Task LoadPendingSyncCount()
    {
        try
        {
            pendingSyncCount = await GlobalSyncService.GetPendingSyncCountAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading sync count: {ex.Message}");
        }
    }

    // Dispose method for timer
    public void Dispose()
    {
        syncStatusTimer?.Dispose();
    }
}