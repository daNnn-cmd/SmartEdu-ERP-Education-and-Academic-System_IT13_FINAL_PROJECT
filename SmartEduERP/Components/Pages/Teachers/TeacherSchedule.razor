@page "/teacher/schedule"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using SmartEduERP.Services
@using SmartEduERP.Data.Models
@using SmartEduERP.Components.Shared
@attribute [Authorize(Roles = "Teacher")]
@inject SubjectService SubjectService
@inject TeacherService TeacherService
@inject AuthStateProvider AuthStateProvider
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Teaching Schedule - SmartEduERP</PageTitle>

<style>
    .dashboard-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f5f5f5;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .sidebar {
        width: 260px;
        background: white;
        border-right: 1px solid #e5e5e5;
        position: fixed;
        height: 100vh;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .sidebar-header {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #e5e5e5;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .sidebar-logo {
        width: 48px;
        height: 48px;
    }

    .sidebar-title {
        font-size: 1rem;
        font-weight: 600;
        margin: 0;
        color: #000;
    }

    .sidebar-subtitle {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .sidebar-content {
        flex: 1;
        padding: 1rem 0;
    }

    .sidebar-section-label {
        padding: 0.5rem 1rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: #737373;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-menu-item {
        padding: 0 0.75rem;
    }

    .sidebar-menu-button {
        width: 100%;
        padding: 0.625rem 0.75rem;
        background: none;
        border: none;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.2s;
        text-decoration: none;
    }

        .sidebar-menu-button:hover {
            background: #f5f5f5;
            color: #000;
        }

        .sidebar-menu-button.active {
            background: #f0f0f0;
            color: #000;
            font-weight: 500;
        }

    .sidebar-menu-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .sidebar-footer {
        padding: 1rem;
        border-top: 1px solid #e5e5e5;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        background: #f0f0f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
    }

    .user-details {
        flex: 1;
        min-width: 0;
    }

    .user-name {
        font-size: 0.875rem;
        font-weight: 500;
        color: #000;
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .user-role {
        font-size: 0.75rem;
        color: #737373;
        margin: 0;
    }

    .logout-button {
        width: 100%;
        padding: 0.625rem;
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 6px;
        font-size: 0.875rem;
        color: #404040;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }

        .logout-button:hover {
            background: #f5f5f5;
            border-color: #d4d4d4;
        }

    .main-content {
        margin-left: 260px;
        flex: 1;
        padding: 1.5rem;
    }

    .dashboard-header {
        margin-bottom: 1.5rem;
    }

        .dashboard-header h1 {
            font-size: 1.75rem;
            font-weight: 600;
            color: #000;
            margin: 0 0 0.25rem 0;
        }

        .dashboard-header p {
            font-size: 0.9375rem;
            color: #737373;
            margin: 0;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        padding: 1.25rem;
    }

    .stat-card-title {
        font-size: 0.875rem;
        font-weight: 500;
        color: #737373;
        margin: 0 0 0.5rem 0;
    }

    .stat-card-value {
        font-size: 1.5rem;
        font-weight: 600;
        color: #000;
        margin: 0;
    }

    .content-card {
        background: white;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        overflow: hidden;
    }

    .content-card-header {
        padding: 1.25rem;
        border-bottom: 1px solid #e5e5e5;
    }

    .content-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: #000;
        margin: 0;
    }

    .content-card-body {
        padding: 1.25rem;
    }

    .schedule-table {
        width: 100%;
        border-collapse: collapse;
    }

        .schedule-table th {
            text-align: left;
            padding: 0.75rem;
            font-size: 0.75rem;
            font-weight: 500;
            color: #737373;
            border-bottom: 1px solid #e5e5e5;
            background: #fafafa;
        }

        .schedule-table td {
            padding: 0.75rem;
            font-size: 0.875rem;
            border-bottom: 1px solid #f5f5f5;
        }

        .schedule-table tr:last-child td {
            border-bottom: none;
        }

        .schedule-table tr:hover {
            background: #fafafa;
        }

    .subject-name {
        font-weight: 500;
        color: #000;
    }

    .text-muted {
        color: #737373;
        font-size: 0.8125rem;
    }

    .badge {
        display: inline-block;
        padding: 0.125rem 0.5rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 500;
        background: #dbeafe;
        color: #1e40af;
        margin-right: 0.25rem;
    }

    .badge-section {
        background: #dcfce7;
        color: #166534;
    }

    .error-message {
        padding: 0.75rem 1rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 6px;
        color: #dc2626;
        font-size: 0.875rem;
        margin-bottom: 1.5rem;
    }

    .empty-state {
        text-align: center;
        padding: 2rem;
        color: #6b7280;
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    .loading-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 300px;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #f5f5f5;
        border-top-color: #000;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

       @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 768px) {
        .dashboard-wrapper {
            flex-direction: column;
        }

        .sidebar {
            position: relative;
            width: 100%;
            height: auto;
        }

        .main-content {
            margin-left: 0;
            padding: 1rem;
        }

        .schedule-table {
            display: block;
            overflow-x: auto;
        }
    }
</style>

<div class="dashboard-wrapper">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo.png" alt="Logo" class="sidebar-logo" />
            <div>
                <h2 class="sidebar-title">Academic System</h2>
                <p class="sidebar-subtitle">Education Management</p>
            </div>
        </div>

        <div class="sidebar-content">
            <div class="sidebar-section-label">Teacher Menu</div>
            <ul class="sidebar-menu">
                <li class="sidebar-menu-item">
                    <a href="/teacher-dashboard" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="7" height="7"></rect>
                            <rect x="14" y="3" width="7" height="7"></rect>
                            <rect x="14" y="14" width="7" height="7"></rect>
                            <rect x="3" y="14" width="7" height="7"></rect>
                        </svg>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-menu-item">
                    <a href="/grades" class="sidebar-menu-button">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 11l3 3L22 4"></path>
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
                        </svg>
                        <span>Grade Management</span>
                    </a>
                </li>
                
                <li class="sidebar-menu-item">
                    <a href="/teacher/schedule" class="sidebar-menu-button active">
                        <svg class="sidebar-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                        <span>Assigned Subjects</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="user-details">
                    <p class="user-name">@userName</p>
                    <p class="user-role">Teacher</p>
                </div>
            </div>
            <button class="logout-button" @onclick="ShowLogoutConfirmation">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                <span>Log Out</span>
            </button>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="dashboard-header">
            <h1>Teaching Schedule</h1>
            <p>View the classes and sections you are assigned to teach.</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="error-message">
                <strong>Error:</strong> @errorMessage
            </div>
        }

        @if (loading)
        {
            <div class="loading-container">
                <div class="spinner"></div>
            </div>
        }
        else
        {
            <div class="stats-grid">
                <div class="stat-card">
                    <p class="stat-card-title">Total Subjects</p>
                    <p class="stat-card-value">@totalSubjects</p>
                </div>
                <div class="stat-card">
                    <p class="stat-card-title">Grade Levels</p>
                    <p class="stat-card-value">@totalGradeLevels</p>
                </div>
                <div class="stat-card">
                    <p class="stat-card-title">Sections</p>
                    <p class="stat-card-value">@totalSections</p>
                </div>
            </div>

            <div class="content-card">
                <div class="content-card-header">
                    <h3 class="content-card-title">Assigned Classes</h3>
                </div>
                <div class="content-card-body">
                    @if (mySubjects.Any())
                    {
                        <div class="table-responsive">
                            <table class="schedule-table">
                                <thead>
                                    <tr>
                                        <th>Grade Level</th>
                                        <th>Section</th>
                                        <th>Subject Code</th>
                                        <th>Subject Name</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var subject in mySubjects)
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge">@subject.GradeLevel</span>
                                            </td>
                                            <td>
                                                <span class="badge badge-section">@subject.Section</span>
                                            </td>
                                            <td>
                                                <span class="text-muted">@subject.SubjectCode</span>
                                            </td>
                                            <td>
                                                <span class="subject-name">@subject.SubjectName</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-icon">📚</div>
                            <p>No subjects have been assigned to you yet.</p>
                            <small>Contact your administrator to get teaching assignments.</small>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<ConfirmationDialog IsVisible="showLogoutConfirmation"
                    Title="Confirm Logout"
                    Message="Are you sure you want to log out? You will need to sign in again to access your dashboard."
                    ConfirmText="Log Out"
                    ProcessingText="Logging out..."
                    Type="ConfirmationDialog.ConfirmationType.Logout"
                    IsProcessing="isLoggingOut"
                    OnConfirm="ConfirmLogout"
                    OnCancel="CancelLogout" />

@code {
    private bool loading = true;
    private string userName = "Teacher";
    private int teacherId;
    private List<Subject> mySubjects = new();
    private string? errorMessage;

    private int totalSubjects = 0;
    private int totalGradeLevels = 0;
    private int totalSections = 0;

    private bool showLogoutConfirmation = false;
    private bool isLoggingOut = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                userName = user.FindFirst(ClaimTypes.GivenName)?.Value + " " + user.FindFirst(ClaimTypes.Surname)?.Value;
                if (string.IsNullOrWhiteSpace(userName))
                    userName = user.Identity?.Name ?? "Teacher";

                var userId = AuthStateProvider.GetCurrentUserId();
                if (userId.HasValue)
                {
                    await LoadTeacherIdFromUserAccount(userId.Value);
                    if (teacherId > 0)
                    {
                        await LoadSchedule();
                    }
                    else
                    {
                        errorMessage = "Teacher record not found. Please contact administrator.";
                    }
                }
                else
                {
                    errorMessage = "Authentication error. Please log in again.";
                }
            }
            else
            {
                errorMessage = "Please log in to access your teaching schedule.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading teaching schedule: {ex.Message}";
            Console.WriteLine($"❌ Error in TeacherSchedule.OnInitializedAsync: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LoadTeacherIdFromUserAccount(int userId)
    {
        try
        {
            var userAccount = await AuthService.GetUserByIdAsync(userId);
            if (userAccount != null && userAccount.ReferenceId.HasValue)
            {
                teacherId = userAccount.ReferenceId.Value;
            }
            else
            {
                await FindTeacherByEmail(userId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error loading teacher ID for schedule: {ex.Message}");
        }
    }

    private async Task FindTeacherByEmail(int userId)
    {
        try
        {
            var userAccount = await AuthService.GetUserByIdAsync(userId);
            if (userAccount != null && !string.IsNullOrEmpty(userAccount.Email))
            {
                var teachers = await TeacherService.GetAllTeachersAsync();
                var matchingTeacher = teachers.FirstOrDefault(t =>
                    t.Email != null &&
                    t.Email.ToLower() == userAccount.Email.ToLower());

                if (matchingTeacher != null)
                {
                    teacherId = matchingTeacher.TeacherId;
                    userAccount.ReferenceId = teacherId;
                    await AuthService.UpdateUserAsync(userAccount);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error finding teacher by email for schedule: {ex.Message}");
        }
    }

    private async Task LoadSchedule()
    {
        try
        {
            mySubjects = await SubjectService.GetSubjectsByTeacherIdAsync(teacherId);

            totalSubjects = mySubjects.Count;
            totalGradeLevels = mySubjects
                .Select(s => s.GradeLevel)
                .Where(g => !string.IsNullOrWhiteSpace(g))
                .Distinct()
                .Count();

            totalSections = mySubjects
                .Select(s => s.Section)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct()
                .Count();
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading teaching schedule. Please try again.";
            Console.WriteLine($"❌ Error loading teaching schedule: {ex.Message}");
        }
    }

    private void ShowLogoutConfirmation()
    {
        showLogoutConfirmation = true;
    }

    private async Task ConfirmLogout()
    {
        isLoggingOut = true;
        StateHasChanged();

        try
        {
            await AuthStateProvider.LogoutAsync();
            Navigation.NavigateTo("/", true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during logout: {ex.Message}");
            AuthStateProvider.MarkUserAsLoggedOut();
            Navigation.NavigateTo("/", true);
        }
        finally
        {
            isLoggingOut = false;
            showLogoutConfirmation = false;
        }
    }

    private void CancelLogout()
    {
        showLogoutConfirmation = false;
    }
}
