    {
        showLogoutConfirmation = false;
        isLoggingOut = false;
        StateHasChanged();
    }

    private async Task ConfirmLogout()
    {
        isLoggingOut = true;
        StateHasChanged();

        try
        {
            if (AuthStateProvider is AuthStateProvider authProvider && authProvider.GetType().GetMethod("LogoutAsync") != null)
            {
                await ((dynamic)AuthStateProvider).LogoutAsync();
            }
            else
            {
                AuthStateProvider.MarkUserAsLoggedOut();
            }

            Navigation.NavigateTo("/", true);
        }
        catch
        {
            AuthStateProvider.MarkUserAsLoggedOut();
            Navigation.NavigateTo("/", true);
        }
    }

    private async Task GlobalSync()
    {
        if (isSyncing) return;

        isSyncing = true;
        syncMessage = "🔄 Syncing bidirectionally (Local ↔ Cloud)...";
        syncStatusClass = "syncing";
        StateHasChanged();

        try
        {
            var result = await BidirectionalSyncService.SyncAsync();

            if (result.Success)
            {
                syncMessage = $"✅ Bidirectional sync successful! +{result.RecordsAdded} ~{result.RecordsUpdated} -{result.RecordsDeleted}";
                syncStatusClass = "success";
                ToastService.ShowSuccess($"Sync completed: {result.RecordsAdded} added, {result.RecordsUpdated} updated");

                await LoadPendingSyncCount();
            }
            else
            {
                var errorMsg = result.Errors.Any() ? string.Join(", ", result.Errors) : "Unknown error";
                syncMessage = $"❌ Sync failed: {errorMsg}";
                syncStatusClass = "error";
                ToastService.ShowWarning($"Sync failed: {errorMsg}");
            }
        }
        catch (Exception ex)
        {
            syncMessage = $"❌ Sync error: {ex.Message}";
            syncStatusClass = "error";
            ToastService.ShowError($"Sync error: {ex.Message}");
        }
        finally
        {
            isSyncing = false;
            StateHasChanged();

            _ = Task.Run(async () =>
            {
                await Task.Delay(5000);
                syncMessage = "";
                syncStatusClass = "";
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    private async Task LoadPendingSyncCount()
    {
        try
        {
            pendingSyncCount = await GlobalSyncService.GetPendingSyncCountAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading sync count: {ex.Message}");
        }
    }

